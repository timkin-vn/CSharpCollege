<Window x:Class="MinesweeperEF.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MinesweeperEF" Height="700" Width="1100" Background="#0B1B2B">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush" Color="#13283D" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4FC3F7" />
        <SolidColorBrush x:Key="TextBrush" Color="#E6E8EB" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Background" Value="#1F3A54" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#4FC3F7" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Margin" Value="0,2,0,10" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="#234464" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0" >
                    <TextBlock Text="API" VerticalAlignment="Center" FontWeight="Bold" />
                    <TextBox x:Name="ApiUrlBox" Width="240" Text="http://localhost:5234" Style="{StaticResource FieldBox}" />
                    <TextBlock Text="Логин" VerticalAlignment="Center" FontWeight="Bold" />
                    <TextBox x:Name="UserBox" Width="160" Style="{StaticResource FieldBox}" />
                    <TextBlock Text="Пароль" VerticalAlignment="Center" FontWeight="Bold" />
                    <PasswordBox x:Name="PassBox" Width="160" Padding="8,6" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Регистрация" Width="140" Click="Register_Click" />
                    <Button Content="Вход" Width="110" Click="Login_Click" />
                    <Button Content="Обновить игры" Width="150" Click="RefreshGames_Click" />
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock Text="Морской Сапёр EF" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="Подключитесь и начните партию" FontStyle="Italic" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,16,0">
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Новая игра" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                        <UniformGrid Columns="2" Rows="3" Margin="0,0,0,6" HorizontalAlignment="Left">
                            <TextBlock Text="Строк" />
                            <TextBox x:Name="RowsBox" Width="90" Text="16" Style="{StaticResource FieldBox}" />
                            <TextBlock Text="Столбцов" />
                            <TextBox x:Name="ColsBox" Width="90" Text="16" Style="{StaticResource FieldBox}" />
                            <TextBlock Text="Мин" />
                            <TextBox x:Name="MinesBox" Width="90" Text="40" Style="{StaticResource FieldBox}" />
                        </UniformGrid>
                        <TextBlock Text="Имя партии" />
                        <TextBox x:Name="NameBox" Width="220" Text="Game" Style="{StaticResource FieldBox}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Старт" Width="120" Click="NewGame_Click" />
                            <Button Content="Очистить форму" Width="150" Click="ClearForm_Click" />
                        </StackPanel>
                        <TextBlock Text="Размер поля до 22x30, число мин меньше количества клеток." FontStyle="Italic" FontSize="11" Foreground="#9FB7CC" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Сохраненные игры" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                        <ListBox x:Name="GamesList" Height="240" SelectionChanged="GamesList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                        <TextBlock Text="{Binding Status}" FontSize="12" Foreground="#A0B7CD" />
                                        <TextBlock Text="{Binding UpdatedAt}" FontSize="10" Foreground="#839AB1" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>

        <Border Grid.Column="1" Grid.Row="0" Style="{StaticResource Card}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                        <StackPanel Width="160">
                            <TextBlock Text="Статус" FontWeight="Bold" />
                            <TextBlock x:Name="StatusText" FontSize="14" />
                        </StackPanel>
                        <StackPanel Width="140">
                            <TextBlock Text="Флаги" FontWeight="Bold" />
                            <TextBlock x:Name="FlagsText" />
                        </StackPanel>
                        <StackPanel Width="160">
                            <TextBlock Text="Поле" FontWeight="Bold" />
                            <TextBlock x:Name="BoardInfoText" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Игра" FontWeight="Bold" />
                            <TextBlock x:Name="GameNameText" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#0A1A29" BorderBrush="#234464" BorderThickness="1" CornerRadius="8">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <UniformGrid x:Name="BoardGrid" Rows="1" Columns="1" Margin="6" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <StatusBar Grid.Row="1" Grid.ColumnSpan="2" Background="#13283D" Foreground="{StaticResource TextBrush}" Padding="10,4">
                <StatusBarItem>
                    <TextBlock Text="ЛКМ — открыть, ПКМ — флаг/вопрос, двойной клик по цифре — авточорд." />
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </DockPanel>
</Window>
