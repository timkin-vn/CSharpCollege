<Window x:Class="MinesweeperEF.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MinesweeperEF" Height="750" Width="1200" 
        Background="#0B1B2B" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush" Color="#13283D" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4FC3F7" />
        <SolidColorBrush x:Key="TextBrush" Color="#E6E8EB" />
        <SolidColorBrush x:Key="DarkBgBrush" Color="#0A1A29" />
        
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Background" Value="#1F3A54" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#4FC3F7" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A4F6F" />
                                <Setter Property="BorderBrush" Value="#5FD3FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1A344C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="#0F2638" />
            <Setter Property="Foreground" Value="#E6E8EB" />
            <Setter Property="BorderBrush" Value="#2C4F6F" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        
        <Style x:Key="SecretBox" TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="#0F2638" />
            <Setter Property="Foreground" Value="#E6E8EB" />
            <Setter Property="BorderBrush" Value="#2C4F6F" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="BorderBrush" Value="#234464" />
            <Setter Property="BorderThickness" Value="1.5" />
        </Style>
        
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
        
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Foreground" Value="#B0C4D4" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="20">
        <!-- Верхняя панель -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Заголовок приложения -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="🌊 Морской Сапёр EF" FontSize="24" FontWeight="Bold" 
                               Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="Подключитесь к серверу и начните партию" 
                               FontSize="12" FontStyle="Italic" Foreground="#8FA7BA" Margin="0,4,0,0" />
                </StackPanel>

                <!-- Форма подключения -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="API:" VerticalAlignment="Center" 
                                   FontWeight="SemiBold" Margin="0,0,8,0" />
                        <TextBox Grid.Column="1" x:Name="ApiUrlBox" Text="http://localhost:5234" 
                                 Style="{StaticResource FieldBox}" Margin="0,0,16,0" />
                        
                        <TextBlock Grid.Column="2" Text="Логин:" VerticalAlignment="Center" 
                                   FontWeight="SemiBold" Margin="0,0,8,0" />
                        <TextBox Grid.Column="3" x:Name="UserBox" 
                                 Style="{StaticResource FieldBox}" Margin="0,0,16,0" />
                        
                        <TextBlock Grid.Column="4" Text="Пароль:" VerticalAlignment="Center" 
                                   FontWeight="SemiBold" Margin="0,0,8,0" />
                        <PasswordBox Grid.Column="5" x:Name="PassBox" 
                                     Style="{StaticResource SecretBox}" Margin="0,0,16,0" />
                        
                        <StackPanel Grid.Column="6" Orientation="Horizontal" Margin="8,0,0,0">
                            <Button Content="Регистрация" Width="110" Height="42" Click="Register_Click" />
                            <Button Content="Вход" Width="90" Height="42" Click="Login_Click" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Левая панель -->
            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <!-- Новая игра -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="⚡ Новая игра" Style="{StaticResource SectionTitle}" />
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Строк" Style="{StaticResource LabelText}" />
                                <TextBox x:Name="RowsBox" Text="16" Style="{StaticResource FieldBox}" />
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Margin="4,0">
                                <TextBlock Text="Столбцов" Style="{StaticResource LabelText}" />
                                <TextBox x:Name="ColsBox" Text="16" Style="{StaticResource FieldBox}" />
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="Мин" Style="{StaticResource LabelText}" />
                                <TextBox x:Name="MinesBox" Text="40" Style="{StaticResource FieldBox}" />
                            </StackPanel>
                        </Grid>
                        
                        <TextBlock Text="Имя партии" Style="{StaticResource LabelText}" />
                        <TextBox x:Name="NameBox" Text="Game" Style="{StaticResource FieldBox}" Margin="0,4,0,16" />
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="🚀 Старт" Width="150" Height="44" Click="NewGame_Click" 
                                    FontSize="14" FontWeight="SemiBold" />
                            <Button Content="Очистить" Width="120" Height="44" Click="ClearForm_Click" 
                                    Background="#1A2F45" BorderBrush="#3A5F7F" />
                        </StackPanel>
                        
                        <TextBlock Text="💡 Размер поля: до 22×30, число мин меньше количества клеток" 
                                   FontStyle="Italic" FontSize="11" Foreground="#7A95AA" 
                                   TextWrapping="Wrap" Margin="0,12,0,0" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Сохраненные игры -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <TextBlock Text="💾 Сохраненные игры" Style="{StaticResource SectionTitle}" 
                                       VerticalAlignment="Center" />
                            <Button Content="🔄 Обновить" Width="110" Height="32" 
                                    HorizontalAlignment="Right" Click="RefreshGames_Click" 
                                    FontSize="12" Padding="8,4" />
                        </Grid>
                        
                        <ListBox x:Name="GamesList" Height="280" SelectionChanged="GamesList_SelectionChanged"
                                 Background="{StaticResource DarkBgBrush}" 
                                 BorderBrush="#234464" BorderThickness="1.5">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#162838" CornerRadius="6" Padding="12,10" 
                                            Margin="4,3" BorderBrush="#2A4F6F" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" 
                                                       FontSize="14" Foreground="#E6E8EB" />
                                            <TextBlock Text="{Binding Status}" FontSize="12" 
                                                       Foreground="#8FA7BA" Margin="0,4,0,2" />
                                            <TextBlock Text="{Binding UpdatedAt}" FontSize="11" 
                                                       Foreground="#6A8199" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Игровое поле -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Информационная панель -->
                    <Border Grid.Row="0" Background="#0F2638" CornerRadius="8" 
                            Padding="20,14" Margin="0,0,0,16" BorderBrush="#2A4F6F" BorderThickness="1.5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="📊 Статус" FontWeight="SemiBold" FontSize="12" 
                                           Foreground="#8FA7BA" />
                                <TextBlock x:Name="StatusText" FontSize="15" FontWeight="Bold" 
                                           Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="🚩 Флаги" FontWeight="SemiBold" FontSize="12" 
                                           Foreground="#8FA7BA" />
                                <TextBlock x:Name="FlagsText" FontSize="15" FontWeight="Bold" 
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="📏 Поле" FontWeight="SemiBold" FontSize="12" 
                                           Foreground="#8FA7BA" />
                                <TextBlock x:Name="BoardInfoText" FontSize="15" FontWeight="Bold" 
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="🎮 Игра" FontWeight="SemiBold" FontSize="12" 
                                           Foreground="#8FA7BA" />
                                <TextBlock x:Name="GameNameText" FontSize="15" FontWeight="Bold" 
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Поле -->
                    <Border Grid.Row="1" Background="{StaticResource DarkBgBrush}" 
                            BorderBrush="#234464" BorderThickness="2" CornerRadius="10">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                                      VerticalScrollBarVisibility="Auto" Padding="8">
                            <UniformGrid x:Name="BoardGrid" Rows="1" Columns="1" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Статус бар -->
        <Border DockPanel.Dock="Bottom" Background="#13283D" CornerRadius="8" 
                Padding="16,10" Margin="0,16,0,0" BorderBrush="#234464" BorderThickness="1.5">
            <TextBlock Foreground="#B0C4D4" FontSize="12">
                <Run Text="💡" />
                <Run Text="ЛКМ — открыть клетку" FontWeight="Medium" />
                <Run Text=" • " Foreground="#5A7A94" />
                <Run Text="ПКМ — поставить флаг/вопрос" FontWeight="Medium" />
                <Run Text=" • " Foreground="#5A7A94" />
                <Run Text="Двойной клик по цифре — автохорд" FontWeight="Medium" />
            </TextBlock>
        </Border>
    </DockPanel>
</Window>