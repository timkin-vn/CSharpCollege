<Window x:Class="CardFile.Wpf.Views.CardEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Редактирование книги" Height="500" Width="500" ResizeMode="NoResize">

	<Window.DataContext>
		<viewmodels:BookViewModel />
	</Window.DataContext>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition />
		</Grid.RowDefinitions>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition />
		</Grid.ColumnDefinitions>

		<TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
		<TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" HorizontalAlignment="Left" Width="300" Margin="5" />

		<TextBlock Grid.Row="1" Grid.Column="0" Text="Автор:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
		<TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Author}" VerticalAlignment="Center" HorizontalAlignment="Left" Width="300" Margin="5" />

		<!-- Жанр -->
		<TextBlock Grid.Row="2" Grid.Column="0" Text="Жанр:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
		<TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Genre}" VerticalAlignment="Center" HorizontalAlignment="Left" Width="300" Margin="5" />

		<TextBlock Grid.Row="3" Grid.Column="0" Text="Год издания:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
		<TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Year}" VerticalAlignment="Center" HorizontalAlignment="Left" Width="300" Margin="5" />

		<TextBlock Grid.Row="4" Grid.Column="0" Text="Количество экземпляров:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
		<TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Copies}" VerticalAlignment="Center" HorizontalAlignment="Left" Width="300" Margin="5" />

		<TextBlock Grid.Row="5" Grid.Column="0" Text="Дата добавления:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
		<DatePicker Grid.Row="5" Grid.Column="1" SelectedDate="{Binding AddedDate}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" Width="300" />

		<TextBlock Grid.Row="6" Grid.Column="0" Text="Дата списания:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
		<StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
			<DatePicker SelectedDate="{Binding DeletedDate}" IsEnabled="{Binding IsDismissalDateEnabled}" 
                        VerticalAlignment="Center" Margin="5" Width="200" />
			<CheckBox VerticalAlignment="Center" IsChecked="{Binding IsWorkingTillNow}" Margin="5">
				<TextBlock Text="В наличии" VerticalAlignment="Center" />
			</CheckBox>
		</StackPanel>

		<StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
			<Button Content="OK" Padding="5" Margin="5" Click="OkButton_Click" />
			<Button Content="Отмена" Padding="5" Margin="5" Click="CancelButton_Click" />
		</StackPanel>
	</Grid>
</Window>