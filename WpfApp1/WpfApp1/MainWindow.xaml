<Window x:Class="SimpleMinesweeper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сапёр" Height="400" Width="400">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5">
            <Button Name="NewGameButton" Content="Новая игра" Click="NewGameButton_Click" Width="100"/>
            <TextBlock Name="StatusText" Text="Ходов: 0" Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>
        <Grid Name="GameGrid"/>
    </DockPanel>
</Window>