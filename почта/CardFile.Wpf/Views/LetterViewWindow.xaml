<Window x:Class="CardFile.Wpf.Views.LetterViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.Wpf.Views" 
        xmlns:viewmodels="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Просмотр письма" Height="400" Width="600" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Window.DataContext>
        <viewmodels:LetterViewModel />
    </Window.DataContext>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <!-- Тема письма -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Тема:" VerticalAlignment="Center" Margin="5" FontWeight="Bold" />
        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Subject}" VerticalAlignment="Center" Margin="5" />

        <!-- Отправитель -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Отправитель:" VerticalAlignment="Center" Margin="5" FontWeight="Bold" />
        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Sender}" VerticalAlignment="Center" Margin="5" Foreground="#555" />

        <!-- Дата -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата:" VerticalAlignment="Center" Margin="5" FontWeight="Bold" />
        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DateText}" VerticalAlignment="Center" Margin="5" />

        <!-- Текст письма (только чтение, но с выделением) -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Текст:" VerticalAlignment="Top" Margin="5" FontWeight="Bold" />
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Body}" IsReadOnly="True" TextWrapping="Wrap" 
                 Margin="5" BorderBrush="LightGray" VerticalScrollBarVisibility="Auto" />

        <!-- Кнопка закрытия -->
        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Right">
            <Button Content="Закрыть" Padding="10,5" Click="CloseButton_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>