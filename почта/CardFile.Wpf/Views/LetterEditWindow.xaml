<Window x:Class="CardFile.Wpf.Views.LetterEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.Wpf.Views" 
        xmlns:viewmodels="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Редактирование письма" Height="400" Width="500" ResizeMode="NoResize">
    <Window.DataContext>
        <viewmodels:LetterViewModel />
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <!-- Поля письма -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Отправитель:" VerticalAlignment="Center" Margin="5" />
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Sender}" Margin="5" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Получатель:" VerticalAlignment="Center" Margin="5" />
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Receiver}" Margin="5" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Тема:" VerticalAlignment="Center" Margin="5" />
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Subject}" Margin="5" />

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Текст:" VerticalAlignment="Top" Margin="5" />
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Body}" AcceptsReturn="True" TextWrapping="Wrap" Margin="5" />

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Дата:" VerticalAlignment="Center" Margin="5" />
        <DatePicker Grid.Row="4" Grid.Column="1" SelectedDate="{Binding Date}" Margin="5" HorizontalAlignment="Left" Width="200" />

        <!-- Галочка "Прочитано" (вместо "Работает до сих пор") -->
        <CheckBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Content="Письмо прочитано" IsChecked="{Binding IsRead}" Margin="5" HorizontalAlignment="Left" />

        <!-- Кнопки -->
        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right">
            <Button Content="OK" Padding="5" Margin="5" Click="OkButton_Click" />
            <Button Content="Отмена" Padding="5" Margin="5" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>