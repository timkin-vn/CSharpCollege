<Window x:Class="Calculator.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:Calculator.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Calculator.Wpf" Height="450" Width="470" MinHeight="450" MinWidth="470">
    <Window.DataContext>
        <viewmodels:MainWindowViewModel />
    </Window.DataContext>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="0.6*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="6"
                   Text="{Binding DisplayValue}" TextAlignment="Right"
                   FontSize="36" Background="Black" Foreground="LawnGreen"
                   Margin="5" Padding="10" Height="60" VerticalAlignment="Center" />

        <Button Grid.Row="1" Grid.Column="4" Content="C" FontSize="28" Margin="5" Click="ClearButton_Click" />
        <Button Grid.Row="1" Grid.Column="5" Content="X -&gt; Y" FontSize="14" Margin="5" Click="MoveXToYButton_Click" Visibility="Collapsed" />

        <Button Grid.Row="2" Grid.Column="0" Content="7" FontSize="28" Margin="5" Click="DigitButton_Click" />
        <Button Grid.Row="2" Grid.Column="1" Content="8" FontSize="28" Margin="5" Click="DigitButton_Click" />
        <Button Grid.Row="2" Grid.Column="2" Content="9" FontSize="28" Margin="5" Click="DigitButton_Click" />
        <Button Grid.Row="2" Grid.Column="4" Content="sin" FontSize="22" Margin="5" Click="SinButton_Click" />
        <Button Grid.Row="2" Grid.Column="5" Content="cos" FontSize="22" Margin="5" Click="CosButton_Click" />

        <Button Grid.Row="3" Grid.Column="0" Content="4" FontSize="28" Margin="5" Click="DigitButton_Click" />
        <Button Grid.Row="3" Grid.Column="1" Content="5" FontSize="28" Margin="5" Click="DigitButton_Click" />
        <Button Grid.Row="3" Grid.Column="2" Content="6" FontSize="28" Margin="5" Click="DigitButton_Click" />
        <Button Grid.Row="3" Grid.Column="4" Content="tg" FontSize="22" Margin="5" Click="TanButton_Click" />
        <Button Grid.Row="3" Grid.Column="5" Content="ctg" FontSize="22" Margin="5" Click="CotButton_Click" />

        <Button Grid.Row="4" Grid.Column="0" Content="1" FontSize="28" Margin="5" Click="DigitButton_Click" />
        <Button Grid.Row="4" Grid.Column="1" Content="2" FontSize="28" Margin="5" Click="DigitButton_Click" />
        <Button Grid.Row="4" Grid.Column="2" Content="3" FontSize="28" Margin="5" Click="DigitButton_Click" />
        <Button Grid.Row="4" Grid.Column="4" Content="+" FontSize="28" Margin="5" Click="OperationButton_Click" />
        <Button Grid.Row="4" Grid.Column="5" Content="-" FontSize="28" Margin="5" Click="OperationButton_Click" />

        <Button Grid.Row="5" Grid.Column="0" Content="0" FontSize="28" Margin="5" Click="DigitButton_Click" />
        <Button Grid.Row="5" Grid.Column="1" Content="." FontSize="28" Margin="5" Click="PointButton_Click" />
        <Button Grid.Row="5" Grid.Column="2" Content="=" FontSize="28" Margin="5" Click="OperationButton_Click" />
        <Button Grid.Row="5" Grid.Column="4" Content="*" FontSize="28" Margin="5" Click="OperationButton_Click" />
        <Button Grid.Row="5" Grid.Column="5" Content="/" FontSize="28" Margin="5" Click="OperationButton_Click" />
    </Grid>
</Window>
