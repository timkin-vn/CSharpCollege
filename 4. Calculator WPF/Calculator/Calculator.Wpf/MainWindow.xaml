<Window x:Class="Calculator.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Calculator.Wpf.ViewModels"
        Title="Калькулятор" Height="600" Width="400"
        MinHeight="500" MinWidth="350"
        Background="#1e1e1e" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Дисплей -->
        <Border Grid.Row="0" Background="Black" CornerRadius="5" Margin="0,0,0,10">
            <TextBlock Text="{Binding Result}" 
                       FontSize="48" Foreground="LightGoldenrodYellow"
                       HorizontalAlignment="Right" VerticalAlignment="Center"
                       Margin="15" TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- Кнопки -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Row 1: √, x², пустая, / -->
            <Button Grid.Row="0" Grid.Column="0" Content="√" FontSize="28" Margin="3" 
                    Click="SqrtButton_Click" Background="#e0e0e0"/>
            <Button Grid.Row="0" Grid.Column="1" Content="x²" FontSize="24" Margin="3" 
                    Click="SqrButton_Click" Background="#e0e0e0"/>
            <Border Grid.Row="0" Grid.Column="2" Background="#1a1a1a" Margin="3"/>
            <Button Grid.Row="0" Grid.Column="3" Content="/" FontSize="28" Margin="3" 
                    Click="OperationButton_Click" Background="#4ecdc4"/>

            <!-- Row 2: 7, 8, 9, * -->
            <Button Grid.Row="1" Grid.Column="0" Content="7" FontSize="28" Margin="3" 
                    Click="DigitButton_Click" Background="#e0e0e0"/>
            <Button Grid.Row="1" Grid.Column="1" Content="8" FontSize="28" Margin="3" 
                    Click="DigitButton_Click" Background="#e0e0e0"/>
            <Button Grid.Row="1" Grid.Column="2" Content="9" FontSize="28" Margin="3" 
                    Click="DigitButton_Click" Background="#e0e0e0"/>
            <Button Grid.Row="1" Grid.Column="3" Content="*" FontSize="28" Margin="3" 
                    Click="OperationButton_Click" Background="#4ecdc4"/>

            <!-- Row 3: 4, 5, 6, - -->
            <Button Grid.Row="2" Grid.Column="0" Content="4" FontSize="28" Margin="3" 
                    Click="DigitButton_Click" Background="#e0e0e0"/>
            <Button Grid.Row="2" Grid.Column="1" Content="5" FontSize="28" Margin="3" 
                    Click="DigitButton_Click" Background="#e0e0e0"/>
            <Button Grid.Row="2" Grid.Column="2" Content="6" FontSize="28" Margin="3" 
                    Click="DigitButton_Click" Background="#e0e0e0"/>
            <Button Grid.Row="2" Grid.Column="3" Content="-" FontSize="28" Margin="3" 
                    Click="OperationButton_Click" Background="#4ecdc4"/>

            <!-- Row 4: 1, 2, 3, + -->
            <Button Grid.Row="3" Grid.Column="0" Content="1" FontSize="28" Margin="3" 
                    Click="DigitButton_Click" Background="#e0e0e0"/>
            <Button Grid.Row="3" Grid.Column="1" Content="2" FontSize="28" Margin="3" 
                    Click="DigitButton_Click" Background="#e0e0e0"/>
            <Button Grid.Row="3" Grid.Column="2" Content="3" FontSize="28" Margin="3" 
                    Click="DigitButton_Click" Background="#e0e0e0"/>
            <Button Grid.Row="3" Grid.Column="3" Content="+" FontSize="28" Margin="3" 
                    Click="OperationButton_Click" Background="#4ecdc4"/>

            <!-- Row 5: C, 0, ,, = -->
            <Button Grid.Row="4" Grid.Column="0" Content="C" FontSize="28" Margin="3" 
                    Click="ClearButton_Click" Background="#ff6b6b"/>
            <Button Grid.Row="4" Grid.Column="1" Content="0" FontSize="28" Margin="3" 
                    Click="DigitButton_Click" Background="#e0e0e0"/>
            <Button Grid.Row="4" Grid.Column="2" Content="," FontSize="28" Margin="3" 
                    Click="DecimalButton_Click" Background="#e0e0e0"/>
            <Button Grid.Row="4" Grid.Column="3" Content="=" FontSize="28" Margin="3" 
                    Click="EqualButton_Click" Background="#ffd93d"/>
        </Grid>
    </Grid>
</Window>