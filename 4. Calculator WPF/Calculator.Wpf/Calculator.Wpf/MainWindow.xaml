<Window x:Class="Calculator.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:Calculator.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Калькулятор" Height="550" Width="400"
        Background="#2b2b2b">

    <Window.DataContext>
        <viewmodels:MainWindowViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Стиль для кнопок -->
        <Style TargetType="Button" x:Key="CalcButtonStyle">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#3b3b3b"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3b3b3b"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <!-- Главная сетка -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Для дисплея -->
            <RowDefinition Height="*"/>
            <!-- Для клавиатуры -->
        </Grid.RowDefinitions>

        <!-- Дисплей -->
        <TextBlock Grid.Row="0" Text="{Binding DisplayValue}" 
                   Background="#2a2a2a" Foreground="White"
                   FontSize="48" TextAlignment="Right"
                   VerticalAlignment="Center" Padding="15"
                   Margin="0,10" />

        <!-- Клавиатура -->
        <Grid Grid.Row="1" Margin="0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Первая строка -->
            <Button Grid.Row="0" Grid.Column="0" Content="C" Style="{StaticResource CalcButtonStyle}" Click="ClearButton_Click" Background="#e74c3c" Foreground="White"/>
            <Button Grid.Row="0" Grid.Column="1" Content="8" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click"/>
            <Button Grid.Row="0" Grid.Column="2" Content="9" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click"/>
            <Button Grid.Row="0" Grid.Column="3" Content="÷" Style="{StaticResource CalcButtonStyle}" Click="OperationButton_Click" Tag="/" Background="#f39c12" Foreground="White"/>

            <!-- Вторая строка -->
            <Button Grid.Row="1" Grid.Column="0" Content="%" Style="{StaticResource CalcButtonStyle}" Click="Procent_Click" Background="#f39c12" Foreground="White"/>
            <Button Grid.Row="1" Grid.Column="1" Content="5" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click"/>
            <Button Grid.Row="1" Grid.Column="2" Content="6" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click"/>
            <Button Grid.Row="1" Grid.Column="3" Content="×" Style="{StaticResource CalcButtonStyle}" Click="OperationButton_Click" Tag="*" Background="#f39c12" Foreground="White"/>

            <!-- Третья строка -->
            <Button Grid.Row="2" Grid.Column="0" Content="1" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click"/>
            <Button Grid.Row="2" Grid.Column="1" Content="2" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click"/>
            <Button Grid.Row="2" Grid.Column="2" Content="3" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click"/>
            <Button Grid.Row="2" Grid.Column="3" Content="-" Style="{StaticResource CalcButtonStyle}" Click="OperationButton_Click" Tag="-" Background="#f39c12" Foreground="White"/>

            <!-- Четвертая строка -->
            <Button Grid.Row="3" Grid.Column="0" Content="0" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click"/>
            <Button Grid.Row="3" Grid.Column="1" Content="," Style="{StaticResource CalcButtonStyle}" Click="Button_Click"/>
            <Button Grid.Row="3" Grid.Column="2" Content="=" Style="{StaticResource CalcButtonStyle}" Click="OperationButton_Click" Tag="=" Background="#2ecc71" Foreground="White"/>
            <Button Grid.Row="3" Grid.Column="3" Content="+" Style="{StaticResource CalcButtonStyle}" Click="OperationButton_Click" Tag="+" Background="#f39c12" Foreground="White"/>
        </Grid>
    </Grid>
</Window>