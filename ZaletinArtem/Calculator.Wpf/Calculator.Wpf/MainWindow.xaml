<Window x:Class="Calculator.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Калькулятор" Height="600" Width="400"
        Background="{DynamicResource WindowBackgroundColor}">
    <Window.Resources>
        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundColor}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundColor}" />
            <Setter Property="BorderBrush" Value="#FFDDDDDD" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <!-- OnHower -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFCFCFCF" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="15" Opacity="0.4" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <!-- OnClick -->
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.2" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Window Styles -->
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundColor}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundColor}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.3" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="1.5*" />
            <RowDefinition Height="6*" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,10,0,10">
            <TextBlock Text="Тема:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource ButtonForegroundColor}"/>
            <ToggleButton Content="Темная" 
                          IsChecked="{Binding IsDarkTheme, Mode=TwoWay}" 
                          Padding="5" />
        </StackPanel>

        <!-- Operation line -->
        <TextBox Text="{Binding CurrentOperationDisplay}" 
                 IsReadOnly="True" 
                 FontSize="16" 
                 Margin="102,0,10,0" 
                 VerticalAlignment="Center" 
                 TextAlignment="Right" 
                 BorderThickness="0" 
                 Background="Transparent" 
                 Foreground="{DynamicResource ButtonForegroundColor}" />

        <!-- Result display -->
        <TextBox Text="{Binding OutputDisplay}" 
                 IsReadOnly="True" 
                 FontSize="30" 
                 VerticalAlignment="Center" 
                 HorizontalAlignment="Stretch" 
                 TextAlignment="Right" 
                 BorderThickness="0" 
                 Background="Transparent" 
                 Foreground="{DynamicResource ButtonForegroundColor}" 
                 Grid.Row="1" />

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Content="7" Grid.Row="0" Grid.Column="0" Click="DigitButton_Click" />
            <Button Content="8" Grid.Row="0" Grid.Column="1" Click="DigitButton_Click" />
            <Button Content="9" Grid.Row="0" Grid.Column="2" Click="DigitButton_Click" />
            <Button Content="÷" Grid.Row="0" Grid.Column="3" Click="OperationButton_Click" />
            <Button Content="%" Grid.Row="0" Grid.Column="4" Click="PercentageButton_Click" />

            <Button Content="4" Grid.Row="1" Grid.Column="0" Click="DigitButton_Click" />
            <Button Content="5" Grid.Row="1" Grid.Column="1" Click="DigitButton_Click" />
            <Button Content="6" Grid.Row="1" Grid.Column="2" Click="DigitButton_Click" />
            <Button Content="×" Grid.Row="1" Grid.Column="3" Click="OperationButton_Click" />
            <Button Content="√" Grid.Row="1" Grid.Column="4" Click="SquareRootButton_Click" />

            <Button Content="1" Grid.Row="2" Grid.Column="0" Click="DigitButton_Click" />
            <Button Content="2" Grid.Row="2" Grid.Column="1" Click="DigitButton_Click" />
            <Button Content="3" Grid.Row="2" Grid.Column="2" Click="DigitButton_Click" />
            <Button Content="−" Grid.Row="2" Grid.Column="3" Click="OperationButton_Click" />
            <Button Content="x^y" Grid.Row="2" Grid.Column="4" Click="PowerButton_Click" />

            <Button Content="C" Grid.Row="3" Grid.Column="0" Click="ClearButton_Click" />
            <Button Content="0" Grid.Row="3" Grid.Column="1" Click="DigitButton_Click" />
            <Button Content="=" Grid.Row="3" Grid.Column="2" Click="OperationButton_Click" />
            <Button Content="+" Grid.Row="3" Grid.Column="3" Click="OperationButton_Click" />

            <Button Content="sin" Grid.Row="4" Grid.Column="0" Click="SinButton_Click" />
            <Button Content="cos" Grid.Row="4" Grid.Column="1" Click="CosButton_Click" />
            <Button Content="tan" Grid.Row="4" Grid.Column="2" Click="TanButton_Click" />
            <Button Content="log" Grid.Row="4" Grid.Column="3" Click="LogButton_Click" />
            <Button Content="ln" Grid.Row="4" Grid.Column="4" Click="LnButton_Click" />
        </Grid>

        <!-- History of operations -->
        <ListBox ItemsSource="{Binding OperationLog}" 
                 Grid.Row="3" 
                 Margin="10" 
                 Background="{DynamicResource ButtonBackgroundColor}" 
                 Foreground="{DynamicResource ButtonForegroundColor}" />
    </Grid>
</Window>