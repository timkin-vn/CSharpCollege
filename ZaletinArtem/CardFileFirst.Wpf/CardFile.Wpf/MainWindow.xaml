<Window x:Class="CardFile.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Картотека" Height="600" Width="800" Background="#f4f4f9" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Стиль кнопок -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45A049" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3E8E41" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для заголовков таблицы -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Grid>
                            <!-- Градиентный фон -->
                            <Border Background="{DynamicResource ColumnHeaderBackground}" CornerRadius="5" Padding="{TemplateBinding Padding}" BorderBrush="#388E3C" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Градиентный фон заголовков -->
        <LinearGradientBrush x:Key="ColumnHeaderBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#66BB6A" Offset="0.0" />
            <GradientStop Color="#4CAF50" Offset="1.0" />
        </LinearGradientBrush>

        <!-- Стиль таблицы -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D3D3D3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="#FFFFFF" />
            <Setter Property="AlternatingRowBackground" Value="#F7F7F7" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0" />
            <Setter Property="VerticalGridLinesBrush" Value="#E0E0E0" />
            <Setter Property="RowHeight" Value="40" />
            <Setter Property="ColumnHeaderHeight" Value="50" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <!-- Стиль строк таблицы -->
        <Style TargetType="DataGridRow">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#333" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DCE775" />
                    <Setter Property="Foreground" Value="#000000" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль ячеек таблицы -->
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="5" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#333" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="0 0 0 1" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#000000" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Картотека книг" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Foreground="#333" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,20" />

        <!-- Таблица с данными -->
        <DataGrid Grid.Row="1" Margin="0,10,0,10" ItemsSource="{Binding Cards}" SelectedItem="{Binding SelectedCard}" 
                  AutoGenerateColumns="False" IsReadOnly="True" BorderBrush="#D3D3D3" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="2*" />
                <DataGridTextColumn Header="Автор" Binding="{Binding Author}" Width="2*" />
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre}" Width="1*" />
                <DataGridTextColumn Header="Дата публикации" Binding="{Binding PublicationDate, StringFormat=dd.MM.yyyy}" Width="1.5*" />
                <DataGridTextColumn Header="Страниц" Binding="{Binding PageCount}" Width="1*" />
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=C}" Width="1*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель кнопок -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Добавить" Width="100" Height="40" Margin="10" Style="{StaticResource ModernButtonStyle}" Click="AddCardButton_Click" />
            <Button Content="Изменить" Width="100" Height="40" Margin="10" Style="{StaticResource ModernButtonStyle}" IsEnabled="{Binding SelectedCard}" Click="EditCardButton_Click" />
            <Button Content="Удалить" Width="100" Height="40" Margin="10" Style="{StaticResource ModernButtonStyle}" IsEnabled="{Binding SelectedCard}" Click="DeleteCardButton_Click" />
            <Button Content="Сохранить" Width="100" Height="40" Margin="10" Style="{StaticResource ModernButtonStyle}" Click="SaveButton_Click" />
            <Button Content="Загрузить" Width="100" Height="40" Margin="10" Style="{StaticResource ModernButtonStyle}" Click="LoadButton_Click" />
        </StackPanel>
    </Grid>
</Window>
