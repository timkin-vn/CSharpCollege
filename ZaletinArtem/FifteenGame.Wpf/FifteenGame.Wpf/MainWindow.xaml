<Window x:Class="FifteenGame.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FifteenGame.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="2048" Height="615" Width="475" Background="#FAF8EF">
    <Window.DataContext>
        <local:MainWindowViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#BBADA0" CornerRadius="10" Margin="10" Padding="10">
            <ItemsControl ItemsSource="{Binding Cells}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="4" Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="2" CornerRadius="5" Width="90" Height="90" Background="{Binding Converter={StaticResource TileColorConverter}}" >
                            <TextBlock Text="{Binding}" FontSize="32" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="◀" Command="{Binding MoveLeftCommand}" Width="60" Height="60" FontSize="24" Background="#8F7A66" Foreground="White" Margin="5" />
            <StackPanel Orientation="Vertical">
                <Button Content="▲" Command="{Binding MoveUpCommand}" Width="60" Height="60" FontSize="24" Background="#8F7A66" Foreground="White" Margin="5" />
                <Button Content="▼" Command="{Binding MoveDownCommand}" Width="60" Height="60" FontSize="24" Background="#8F7A66" Foreground="White" Margin="5" />
            </StackPanel>
            <Button Content="▶" Command="{Binding MoveRightCommand}" Width="60" Height="60" FontSize="24" Background="#8F7A66" Foreground="White" Margin="5" />
        </StackPanel>
    </Grid>
</Window>
