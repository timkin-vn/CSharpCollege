<Window x:Class="CardFile.Wpf.Views.EditCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование книги" Height="362" Width="450" WindowStartupLocation="CenterOwner"
        Background="#f9f9f9" BorderBrush="#c5c5c5" BorderThickness="1">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Title -->
        <TextBlock Text="Название:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="14" />
        <TextBox Text="{Binding Title}" Grid.Row="0" Grid.Column="1" Margin="0,5,0,10" Padding="5" />

        <!-- Author -->
        <TextBlock Text="Автор:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontSize="14" />
        <TextBox Text="{Binding Author}" Grid.Row="1" Grid.Column="1" Margin="0,5,0,10" Padding="5" />

        <!-- Publication Date -->
        <TextBlock Text="Дата публикации:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontSize="14" />
        <DatePicker SelectedDate="{Binding PublicationDate}" Grid.Row="2" Grid.Column="1" Margin="0,5,0,10" />

        <!-- Genre -->
        <TextBlock Text="Жанр:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" FontSize="14" />
        <TextBox Text="{Binding Genre}" Grid.Row="3" Grid.Column="1" Margin="0,5,0,10" Padding="5" />

        <!-- Page Count -->
        <TextBlock Text="Количество страниц:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontSize="14" />
        <TextBox Text="{Binding PageCount}" Grid.Row="4" Grid.Column="1" Margin="0,5,0,10" Padding="5" />

        <!-- Price -->
        <TextBlock Text="Цена:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" FontSize="14" />
        <TextBox Text="{Binding Price}" Grid.Row="5" Grid.Column="1" Margin="0,5,0,10" Padding="5" />

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" Grid.Row="6" Grid.ColumnSpan="2" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Сохранить" Width="100" Margin="5" Padding="8" Background="#4caf50" Foreground="White" FontSize="14" />
            <Button Content="Отмена" Width="100" Margin="5" Padding="8" Background="#f44336" Foreground="White" FontSize="14" />
        </StackPanel>
    </Grid>
</Window>
