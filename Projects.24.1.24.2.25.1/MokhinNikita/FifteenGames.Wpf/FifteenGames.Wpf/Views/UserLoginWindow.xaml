<Window x:Class="FifteenGames.Wpf.Views.UserLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FifteenGames.Wpf.Views"
        xmlns:viewModels="clr-namespace:FifteenGames.Wpf.ViewModels"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="Вход в систему" Height="150" Width="300" MinHeight="150" MinWidth="300" MaxWidth="300" MaxHeight="150">
    <Window.DataContext>
        <viewModels:UserLoginViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Text="Имя пользователя:" Margin="5"/>
        <TextBox Grid.Row="1" Margin="5" Text="{Binding UserName}" />
        <Button Grid.Row="2" Content="OK" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5" Padding="5" Click="OKClick"/>
    </Grid>
</Window>
