<Window x:Class="LimerList.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LimerList" xmlns:viewmodels="clr-namespace:LimerList.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="450" Width="800" Loaded="Window_Loaded" Initialized="Window_Initialized" Closing="Window_Closing">
    <Window.DataContext>
        <viewmodels:MainViewModel/>
    </Window.DataContext>
    <Window.CommandBindings>
        <CommandBinding Command="Save" CanExecute="FunctionCanExecute" Executed="SaveExecuted"></CommandBinding>
        <CommandBinding Command="SaveAs" CanExecute="FunctionCanExecute" Executed="SaveAsExecuted"></CommandBinding>
        <CommandBinding Command="Open" CanExecute="FunctionCanExecute" Executed="OpenExecuted"></CommandBinding>
    </Window.CommandBindings>
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom"></StatusBar>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Command="Open"></MenuItem>
                <MenuItem Command="Save"></MenuItem>
                <MenuItem Command="SaveAs"></MenuItem>
                <Separator/>
                <MenuItem Header="_Выход" Click="ExitClick"></MenuItem>
            </MenuItem>
            <MenuItem Header="_Справка">
                <MenuItem Header="_О списке учеников" Click="AboutClick" ></MenuItem>
            </MenuItem>
        </Menu>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <DataGrid ItemsSource="{Binding Limers}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" IsReadOnly="True" Margin="5" SelectionChanged="DataGrid_SelectionChanged" SelectedItem="{Binding SelectedLimer}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FIO}"></DataGridTextColumn>
                    <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDateString}"/>
                    <DataGridTextColumn Header="Группа" Binding="{Binding Group}"/>
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Margin="5" Padding="5" Click="NewButtonClicked">New</Button>
                <Button Margin="5" Padding="5" Click="EditButtonClicked" IsEnabled="{Binding IsEditButtonEnabled}">Edit</Button>
                <Button Margin="5" Padding="5" Click="DeleteButton_Click" IsEnabled="{Binding IsDeleteButtonEnabled}">Delete</Button>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
