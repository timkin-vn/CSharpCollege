<Window x:Class="LimerList.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LimerList.Views" xmlns:viewmodels="clr-namespace:LimerList.ViewModels"
        mc:Ignorable="d"
        Title="О картотеке" Height="400" Width="400" ResizeMode="NoResize">
    <Window.DataContext>
        <viewmodels:AboutViewModel/>
    </Window.DataContext>
    <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" HorizontalAlignment="Right">
            <Button Margin="5" Padding="5" Content="OK" Click="OKClick"/>
        </StackPanel>
        <Grid>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding Copyright}" HorizontalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Center">
                    Версия <Run Text="{Binding Version, Mode=OneWay}" /> (<Run Text="{Binding FileVersion, Mode=OneWay}"/>)
                </TextBlock>
                <TextBlock Text="{Binding Seminar}" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                <TextBlock Text="{Binding Monitor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
