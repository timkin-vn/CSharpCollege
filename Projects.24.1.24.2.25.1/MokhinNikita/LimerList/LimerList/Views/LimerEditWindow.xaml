<Window x:Class="LimerList.Views.LimerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LimerList.Views" xmlns:viewmodels="clr-namespace:LimerList.ViewModels"
        mc:Ignorable="d"
        Title="Правка элемента" Height="400" Width="400" ResizeMode="NoResize">
    <Window.DataContext>
        <viewmodels:LimerViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Text="Имя" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"></TextBlock>
        <TextBox Text="{Binding FirstName}" Margin="5" Width="200" Grid.Column="1" HorizontalAlignment="Left"></TextBox>
        <TextBlock Grid.Row="1" Text="Фамилия" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"></TextBlock>
        <TextBox Grid.Row="1" Text="{Binding LastName}" Margin="5" Width="200" Grid.Column="1" HorizontalAlignment="Left"></TextBox>
        <TextBlock Grid.Row="2" Text="Отчество" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"></TextBlock>
        <TextBox Grid.Row="2" Text="{Binding MiddleName}" Margin="5" Width="200" Grid.Column="1" HorizontalAlignment="Left"></TextBox>
        <TextBlock Grid.Row="3" Text="Дата рождения" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"></TextBlock>
        <DatePicker Grid.Row="3" Grid.Column="1" Margin="5" Width="200" HorizontalAlignment="Left" VerticalAlignment="Center" SelectedDate="{Binding BirthDate}"/>
        <TextBlock Grid.Row="4" Text="Группа" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"></TextBlock>
        <TextBox Grid.Row="4" Text="{Binding Group}" Margin="5" Width="200" Grid.Column="1" HorizontalAlignment="Left"></TextBox>
        <StackPanel Grid.ColumnSpan="2" Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="OK" Click="OkClicked" Margin="5" Padding="5"></Button>
            <Button Content="Cancel" Click="CancelClicked" Margin="5" Padding="5"></Button>
        </StackPanel>
    </Grid>
</Window>
