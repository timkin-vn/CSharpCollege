<Window x:Class="Game2048.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Игра 2048"
        Height="520"
        Width="400"
        Background="#FAF8EF"
        KeyDown="Window_KeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка: Счет и статус -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <Grid>
                <TextBlock Text="2048" FontSize="36" FontWeight="Bold" Foreground="#776E65"/>
                <Border Background="#BBADA0" CornerRadius="3" HorizontalAlignment="Right" Padding="15,5">
                    <StackPanel>
                        <TextBlock Text="СЧЕТ" FontSize="10" Foreground="#EEE4DA" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Score}" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
            <TextBlock Text="{Binding StatusText}" FontSize="14" FontWeight="Bold" Foreground="#776E65" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Клеточное поле 4х4 -->
        <Border Grid.Row="1" Background="#BBADA0" CornerRadius="6" Padding="10">
            <ItemsControl ItemsSource="{Binding Cells}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" Rows="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5" Background="#CDC1B4" CornerRadius="4">
                            <TextBlock Text="{Binding DisplayText}" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       FontSize="24" 
                                       FontWeight="Bold" 
                                       Foreground="#776E65"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Кнопка сброса -->
        <Button Grid.Row="2" Content="Начать заново" Margin="0,15,0,0" Padding="10" 
                Background="#8F7A66" Foreground="White" FontWeight="Bold" FontSize="16"
                Click="Button_Click" BorderThickness="0"/>
    </Grid>
</Window>
