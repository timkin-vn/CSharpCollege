<Window x:Class="Game2048.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Игра 2048"
        Height="660"
        Width="400"
        Background="#FAF8EF"
        KeyDown="Window_KeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка: Название, Кнопка сброса, Счет и статус -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="2048" FontSize="36" FontWeight="Bold" Foreground="#776E65"/>
                    <Button Content="Заново" Margin="15,0,0,0" Padding="10,5" 
                            Background="#8F7A66" Foreground="White" FontWeight="Bold" FontSize="14"
                            Click="Button_Click" BorderThickness="0" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Background="#BBADA0" CornerRadius="3" HorizontalAlignment="Right" Padding="15,5">
                    <StackPanel>
                        <TextBlock Text="СЧЕТ" FontSize="10" Foreground="#EEE4DA" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Score}" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
            <TextBlock Text="{Binding StatusText}" FontSize="14" FontWeight="Bold" Foreground="#776E65" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- 
            КЛЕТОЧНОЕ ПОЛЕ 4х4
            Обеспечивает 100% дискретное отображение. Данные обновляются мгновенно через Binding.
            В шаблоне отсутствуют анимации сдвига (Storyboard/DoubleAnimation), что исключает плавные переходы.
        -->
        <Border Grid.Row="1" Background="#BBADA0" CornerRadius="6" Padding="10">
            <ItemsControl ItemsSource="{Binding Cells}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" Rows="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5" Background="#CDC1B4" CornerRadius="4">
                            <TextBlock Text="{Binding DisplayText}" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       FontSize="24" 
                                       FontWeight="Bold" 
                                       Foreground="#776E65"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- 
            ПУЛЬТ УПРАВЛЕНИЯ КНОПКАМИ-СТРЕЛКАМИ
            Реализует пошаговый режим игры. Приложение реагирует только на точечный клик 
            пользователя по кнопкам, выполняет один дискретный шаг и возвращается в режим ожидания.
        -->
        <Grid Grid.Row="2" Margin="0,15,0,0" HorizontalAlignment="Center" Width="180" Height="120">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Кнопка ВВЕРХ -->
            <Button x:Name="BtnMoveUp" Grid.Row="0" Grid.Column="1" Content="▲" Margin="3"
                    Background="#8F7A66" Foreground="White" FontSize="18" FontWeight="Bold"
                    BorderThickness="0" Click="BtnMoveUp_Click"/>

            <!-- Кнопка ВЛЕВО -->
            <Button x:Name="BtnMoveLeft" Grid.Row="1" Grid.Column="0" Content="◀" Margin="3"
                    Background="#8F7A66" Foreground="White" FontSize="18" FontWeight="Bold"
                    BorderThickness="0" Click="BtnMoveLeft_Click"/>

            <!-- Кнопка ВНИЗ -->
            <Button x:Name="BtnMoveDown" Grid.Row="1" Grid.Column="1" Content="▼" Margin="3"
                    Background="#8F7A66" Foreground="White" FontSize="18" FontWeight="Bold"
                    BorderThickness="0" Click="BtnMoveDown_Click"/>

            <!-- Кнопка ВПРАВО -->
            <Button x:Name="BtnMoveRight" Grid.Row="1" Grid.Column="2" Content="▶" Margin="3"
                    Background="#8F7A66" Foreground="White" FontSize="18" FontWeight="Bold"
                    BorderThickness="0" Click="BtnMoveRight_Click"/>
        </Grid>
    </Grid>
</Window>
