@page "/"
@using Game2048.Business.Models
@using Game2048.Web.Services
@inject GameHttpProxy GameProxy

<div class="game-container" @onkeydown="HandleKeyDown" tabindex="0">
    
    <!-- Шапка: Название, Кнопка сброса, Счет -->
    <div class="header">
        <div class="title-section">
            <span class="logo">2048</span>
            <button class="btn-restart" @onclick="async () => await RestartGame()">Заново</button>
        </div>
        <div class="score-box">
            <div class="score-label">СЧЕТ</div>
            <div class="score-value">@_gameModel.Score</div>
        </div>
    </div>

    <!-- Статус игры -->
    <div class="status-text">
        @if (_gameModel.IsWin)
        {
            <span class="win">Вы победили! 2048 собрано!</span>
        }
        else if (_gameModel.IsGameOver)
        {
            <span class="fail">Игра окончена. Ходов больше нет.</span>
        }
        else
        {
            <span>Игра в процессе...</span>
        }
    </div>

    <!-- Клеточное поле 4х4 -->
    <div class="board">
        @for (int r = 0; r < GameModel.BoardSize; r++)
        {
            @for (int c = 0; c < GameModel.BoardSize; c++)
            {
                var val = _gameModel.Board[r, c];
                <div class="cell tile-@val">
                    @(val == 0 ? "" : val.ToString())
                </div>
            }
        }
    </div>

    <div class="dpad-container">
        <div class="dpad">
            <button class="btn-arrow up" @onclick="async () => await ExecuteMove(MoveDirection.Up)">▲</button>
            <button class="btn-arrow left" @onclick="async () => await ExecuteMove(MoveDirection.Left)">◀</button>
            <button class="btn-arrow down" @onclick="async () => await ExecuteMove(MoveDirection.Down)">▼</button>
            <button class="btn-arrow right" @onclick="async () => await ExecuteMove(MoveDirection.Right)">▶</button>
        </div>
    </div>

    <div class="db-section">
        <h4>Сохранить результат в БД</h4>
        <div class="save-box">
            <input @bind="_playerName" placeholder="Ваше имя" class="input-name" />
            <button class="btn-save" @onclick="SaveScoreToDb">Сохранить</button>
        </div>

        @if (_isSaved)
        {
            <div class="save-status">✓ Результат сохранен в SQLite!</div>
        }

        <h4 class="leaderboard-title">🏆 Топ-10 результатов из БД</h4>
        <ul class="leaderboard-list">
            @if (_leaderboard == null)
            {
                <li>Загрузка...</li>
            }
            else if (!_leaderboard.Any())
            {
                <li>Таблица рекордов пуста. Будьте первым!</li>
            }
            else
            {
                @foreach (var record in _leaderboard)
                {
                    <li>
                        <span class="player-name">@record.PlayerName</span>
                        <span class="player-score">@record.Score очков</span>
                    </li>
                }
            }
        </ul>
    </div>
</div>

@code {
    private GameModel _gameModel = new GameModel();
    private string _playerName = "Игрок";
    private bool _isSaved = false;
    private List<GameHttpProxy.GameSessionDto> _leaderboard = new();

    protected override async Task OnInitializedAsync()
    {
        _gameModel = await GameProxy.RestartGameAsync();
        await RefreshLeaderboard(); 
    }

    private async Task ExecuteMove(MoveDirection direction)
    {
        if (_gameModel.IsGameOver) return;

        _gameModel = await GameProxy.ExecuteMoveAsync(direction);
        _isSaved = false; 
        StateHasChanged();
    }

    private async Task RestartGame()
    {
        _gameModel = await GameProxy.RestartGameAsync();
        _isSaved = false;
        StateHasChanged();
    }

    private async Task SaveScoreToDb()
    {
        if (string.IsNullOrWhiteSpace(_playerName)) return;

        try
        {
            await GameProxy.SaveGameResultAsync(_playerName);
            _isSaved = true;
            await RefreshLeaderboard(); 
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка сохранения: {ex.Message}");
        }
    }

    private async Task RefreshLeaderboard()
    {
        try
        {
            _leaderboard = await GameProxy.GetLeaderboardAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки топа: {ex.Message}");
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        MoveDirection? direction = e.Key switch
        {
            "ArrowUp" => MoveDirection.Up,
            "ArrowDown" => MoveDirection.Down,
            "ArrowLeft" => MoveDirection.Left,
            "ArrowRight" => MoveDirection.Right,
            _ => null
        };

        if (direction.HasValue)
        {
            await ExecuteMove(direction.Value);
        }
    }
}

<style>
    .game-container { width: 400px; margin: 20px auto; font-family: 'Arial', sans-serif; background: #FAF8EF; padding: 20px; border-radius: 8px; outline: none; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
    .logo { font-size: 36px; font-weight: bold; color: #776E65; }
    .btn-restart { margin-left: 15px; padding: 10px 15px; background: #8F7A66; color: white; border: none; font-weight: bold; border-radius: 4px; cursor: pointer; }
    .score-box { background: #BBADA0; padding: 5px 20px; border-radius: 4px; text-align: center; color: white; min-width: 60px; }
    .score-label { font-size: 10px; color: #EEE4DA; font-weight: bold; }
    .score-value { font-size: 20px; font-weight: bold; }
    .status-text { font-size: 14px; font-weight: bold; color: #776E65; margin-bottom: 15px; }
    .win { color: #2ecc71; } .fail { color: #e74c3c; }

    .board { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; background: #BBADA0; padding: 10px; border-radius: 6px; }
    .cell { height: 75px; background: #CDC1B4; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: bold; color: #776E65; transition: none !important; }
    
    .tile-2 { background: #eee4da; color: #776E65; }
    .tile-4 { background: #ede0c8; color: #776E65; }
    .tile-8 { background: #f2b179; color: white; }
    .tile-16 { background: #f59563; color: white; }
    .tile-32 { background: #f67c5f; color: white; }
    .tile-64 { background: #f65e3b; color: white; }
    .tile-128 { background: #edcf72; color: white; font-size: 20px; }
    .tile-256 { background: #edcc61; color: white; font-size: 20px; }
    .tile-512 { background: #edc850; color: white; font-size: 20px; }
    .tile-1024 { background: #edc53f; color: white; font-size: 18px; }
    .tile-2048 { background: #edc22e; color: white; font-size: 18px; }
    
    .dpad-container { display: flex; justify-content: center; margin-top: 20px; }
    .dpad { display: grid; grid-template-columns: repeat(3, 1fr); grid-template-rows: repeat(2, 1fr); width: 180px; height: 120px; gap: 6px; }
    .btn-arrow { background: #8F7A66; color: white; border: none; font-size: 18px; font-weight: bold; border-radius: 4px; cursor: pointer; }
    .btn-arrow:active { background: #705F50; }
    .up { grid-column: 2; grid-row: 1; }
    .left { grid-column: 1; grid-row: 2; }
    .down { grid-column: 2; grid-row: 2; }
    .right { grid-column: 3; grid-row: 2; }

    .db-section { margin-top: 25px; padding-top: 15px; border-top: 2px solid #BBADA0; font-family: sans-serif; color: #776E65; }
    .db-section h4 { margin: 10px 0; font-size: 16px; }
    .save-box { display: flex; gap: 8px; }
    .input-name { flex: 1; padding: 8px; border: 1px solid #BBADA0; border-radius: 4px; outline: none; }
    .btn-save { padding: 8px 15px; background: #2ecc71; color: white; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; }
    .btn-save:active { background: #27ae60; }
    .save-status { color: #2ecc71; font-size: 12px; margin-top: 5px; font-weight: bold; }
    .leaderboard-title { margin-top: 20px !important; }
    .leaderboard-list { list-style: none; padding: 0; margin: 0; background: #eee4da; border-radius: 6px; padding: 8px; }
    .leaderboard-list li { display: flex; justify-content: space-between; padding: 6px 10px; font-size: 14px; border-bottom: 1px solid #CDC1B4; }
    .leaderboard-list li:last-child { border-bottom: none; }
    .player-name { font-weight: bold; }
</style>
