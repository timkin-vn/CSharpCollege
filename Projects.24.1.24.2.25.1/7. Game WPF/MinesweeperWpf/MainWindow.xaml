<Window x:Class="MinesweeperWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сапёр WPF"
        SizeToContent="WidthAndHeight"
        MinWidth="470"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="CellButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#777777" />
            <Setter Property="Background" Value="#DCDCDC" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" Background="#F2F2F2">
        <Border DockPanel.Dock="Top" Margin="10" Padding="10" MinWidth="450" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="Сапёр" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" />
                <TextBlock Text="ЛКМ — открыть клетку, ПКМ — поставить или убрать флажок" Margin="0,4,0,8" HorizontalAlignment="Center" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock Text="Сложность:" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" Margin="0,0,8,0" />
                    <ComboBox x:Name="DifficultyComboBox" Width="185" SelectionChanged="DifficultyComboBox_SelectionChanged">
                        <ComboBoxItem Content="Лёгкий — 9×9, 10 мин" />
                        <ComboBoxItem Content="Средний — 12×12, 25 мин" />
                        <ComboBoxItem Content="Тяжёлый — 16×16, 50 мин" />
                    </ComboBox>

                    <TextBlock Text="Первый ход:" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" Margin="16,0,8,0" />
                    <ComboBox x:Name="FirstMoveComboBox" Width="130" SelectionChanged="FirstMoveComboBox_SelectionChanged">
                        <ComboBoxItem Content="Безопасный" />
                        <ComboBoxItem Content="Опасный" />
                    </ComboBox>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="MinesTextBlock" Grid.Column="0" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" />
                    <Button Grid.Column="1" Content="Новая игра" Padding="12,6" Click="NewGameButton_Click" />
                    <TextBlock x:Name="OpenedTextBlock" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="16" FontWeight="SemiBold" />
                </Grid>

                <TextBlock x:Name="StatusTextBlock" Margin="0,8,0,0" FontSize="16" FontWeight="SemiBold" TextAlignment="Center" />
            </StackPanel>
        </Border>

        <Border Margin="10,0,10,10" Padding="8" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="6" HorizontalAlignment="Center">
            <Grid x:Name="GameGrid" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    </DockPanel>
</Window>
