<Window x:Class="CardFile.Wpf.Views.CardEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.Wpf.Views" xmlns:viewmodels="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Правка сборки" Height="600" Width="520" ResizeMode="NoResize"
        Background="#1E1E1E" Foreground="#FFFFFF">
    <Window.DataContext>
        <viewmodels:CardViewModel />
    </Window.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="Bg" Color="#1E1E1E" />
        <SolidColorBrush x:Key="Surface2" Color="#2D2D30" />
        <SolidColorBrush x:Key="Border" Color="#3F3F46" />
        <SolidColorBrush x:Key="Text" Color="#FFFFFF" />
        <SolidColorBrush x:Key="Selection" Color="#264F78" />

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{StaticResource Surface2}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="CaretBrush" Value="{StaticResource Text}" />
            <Setter Property="SelectionBrush" Value="{StaticResource Selection}" />
            <Setter Property="Padding" Value="6,3" />
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="{StaticResource Surface2}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="Padding" Value="4,2" />
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Background" Value="{StaticResource Surface2}" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource Selection}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Selection}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource Surface2}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
    </Window.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Герой:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
            <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                <TextBox Text="{Binding HeroSearchText}" Width="320" Margin="0,0,0,5" />
                <ComboBox ItemsSource="{Binding FilteredHeroes}" SelectedItem="{Binding Hero}" Width="320" />
            </StackPanel>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Слот 1:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                <TextBox Text="{Binding Slot1SearchText}" Width="320" Margin="0,0,0,5" />
                <ComboBox ItemsSource="{Binding FilteredItemsSlot1}" SelectedItem="{Binding Slot1}" Width="320" />
            </StackPanel>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Слот 2:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="5">
                <TextBox Text="{Binding Slot2SearchText}" Width="320" Margin="0,0,0,5" />
                <ComboBox ItemsSource="{Binding FilteredItemsSlot2}" SelectedItem="{Binding Slot2}" Width="320" />
            </StackPanel>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Слот 3:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
            <StackPanel Grid.Row="3" Grid.Column="1" Margin="5">
                <TextBox Text="{Binding Slot3SearchText}" Width="320" Margin="0,0,0,5" />
                <ComboBox ItemsSource="{Binding FilteredItemsSlot3}" SelectedItem="{Binding Slot3}" Width="320" />
            </StackPanel>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Слот 4:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
            <StackPanel Grid.Row="4" Grid.Column="1" Margin="5">
                <TextBox Text="{Binding Slot4SearchText}" Width="320" Margin="0,0,0,5" />
                <ComboBox ItemsSource="{Binding FilteredItemsSlot4}" SelectedItem="{Binding Slot4}" Width="320" />
            </StackPanel>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Слот 5:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
            <StackPanel Grid.Row="5" Grid.Column="1" Margin="5">
                <TextBox Text="{Binding Slot5SearchText}" Width="320" Margin="0,0,0,5" />
                <ComboBox ItemsSource="{Binding FilteredItemsSlot5}" SelectedItem="{Binding Slot5}" Width="320" />
            </StackPanel>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Слот 6:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
            <StackPanel Grid.Row="6" Grid.Column="1" Margin="5">
                <TextBox Text="{Binding Slot6SearchText}" Width="320" Margin="0,0,0,5" />
                <ComboBox ItemsSource="{Binding FilteredItemsSlot6}" SelectedItem="{Binding Slot6}" Width="320" />
            </StackPanel>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="Нейтралка:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
            <StackPanel Grid.Row="7" Grid.Column="1" Margin="5">
                <TextBox Text="{Binding NeutralSearchText}" Width="320" Margin="0,0,0,5" />
                <ComboBox ItemsSource="{Binding FilteredNeutrals}" SelectedItem="{Binding Neutral}" Width="320" />
            </StackPanel>

            <TextBlock Grid.Row="8" Grid.Column="0" Text="Новый герой:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
            <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" Margin="5">
                <TextBox Text="{Binding NewHeroName}" Width="220" Margin="0,0,5,0" />
                <Button Content="Добавить" Padding="5" Click="AddHeroButton_Click" />
            </StackPanel>

            <TextBlock Grid.Row="9" Grid.Column="0" Text="Новый предмет:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
            <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal" Margin="5">
                <TextBox Text="{Binding NewItemName}" Width="220" Margin="0,0,5,0" />
                <Button Content="Добавить" Padding="5" Click="AddItemButton_Click" />
            </StackPanel>

            <TextBlock Grid.Row="10" Grid.Column="0" Text="Новая нейтралка:" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />
            <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal" Margin="5">
                <TextBox Text="{Binding NewNeutralName}" Width="220" Margin="0,0,5,0" />
                <Button Content="Добавить" Padding="5" Click="AddNeutralButton_Click" />
            </StackPanel>

            <StackPanel Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                <Button Content="OK" Padding="5" Margin="5" Click="OkButton_Click" />
                <Button Content="Отмена" Padding="5" Margin="5" Click="CancelButton_Click" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
