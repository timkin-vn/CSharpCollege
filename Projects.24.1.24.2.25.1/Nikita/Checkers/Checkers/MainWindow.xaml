<Window x:Class="Checkers.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Checkers" xmlns:converters="clr-namespace:Checkers.Converters"
        
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <converters:BoolToColorConverter x:Key="boolToColor"/>
        <converters:CheckerColorConverter x:Key="checkerColor"/>
        <converters:BoolToVisibilityConverter x:Key="boolToVsibility"/>
        <converters:CheckerVisibilityConverter x:Key="checkerVisibility"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#4A90D9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#357ABD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,10" HorizontalAlignment="Center">
            <TextBlock Text="Игра в шашки" FontSize="28" FontWeight="Bold" 
                       Foreground="#2C3E50" TextAlignment="Center"/>
            <TextBlock Text="{Binding CurrentPlayerText, FallbackValue=Белые}" 
                       FontSize="18" FontWeight="SemiBold" 
                       Foreground="#34495E" TextAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="Ход: Белые"/>
                        <Setter Property="Text" Value="{Binding CurrentPlayerText, StringFormat='Ход: {0}'}"/>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
        <ItemsControl Grid.Row="1" 
                      ItemsSource="{Binding BoardCells}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="8" Columns="8"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="0.5"
                    Background="{Binding IsDark, Converter={StaticResource boolToColor}}">
                        <Button Command="{Binding DataContext.CellCheckCommand, 
                            RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid Background="{TemplateBinding Background}">
                                        <!-- Подсветка выбранной клетки -->
                                        <Border Background="{Binding IsSelected, Converter={StaticResource boolToColor}, 
                                                ConverterParameter='Selection'}"
                                        Opacity="0.3"/>

                                        <!-- Подсветка возможного хода -->
                                        <Border Background="{Binding IsValidMove, Converter={StaticResource boolToColor}, 
                                                ConverterParameter='ValidMove'}"
                                        Opacity="0.4"/>

                                        <!-- Шашка -->
                                        <Ellipse Width="40" Height="40" 
                                         Stroke="Black" StrokeThickness="1"
                                         Fill="{Binding Checker.Color, Converter={StaticResource checkerColor}}">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Checker}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Checker}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Checker.Color}" Value="White">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Checker.Color}" Value="Black">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>

                                        <!-- Корона для дамки -->
                                        <TextBlock Text="♕" FontSize="24" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           Foreground="Gold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Checker.IsQueen}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Border>

                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <StackPanel Grid.Row="2" Margin="0,20,0,0" HorizontalAlignment="Center">
            <TextBlock Text="{Binding WinnerText}" FontSize="20" FontWeight="Bold" 
   Foreground="#E74C3C" TextAlignment="Center" Margin="0,0,0,10"/>
            <Button Content="Новая игра" Width="150" Click="Restart"/>
        </StackPanel>
    </Grid>
</Window>
