<Window x:Class="Checkers.Views.UserLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Checkers.Views"
        mc:Ignorable="d"
        Title="UserLoginWindow" Height="116" Width="400">
    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Margin="5" Padding="5" Click="OKClick">
                OK
            </Button>
            <Button Margin="5" Padding="5" Click="CancelClick">
                Отмена
            </Button>
        </StackPanel>
        <TextBox Margin="5" VerticalAlignment="Center" Name="userNameTextBox"></TextBox>
    </DockPanel>
</Window>
