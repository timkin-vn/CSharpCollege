<Window x:Class="CardFile.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.WPF" xmlns:viewmodels="clr-namespace:CardFile.WPF.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="450" Width="800" Loaded="Window_Loaded" Initialized="Window_Initialized" Closing="Window_Closing">
    <Window.CommandBindings>
        <CommandBinding Command="Open" CanExecute="Open_CanExecute" Executed="Open_Executed"/>
        <CommandBinding CanExecute="Save_CanExecute" Executed="Save_Executed" Command="Save"/>
        <CommandBinding CanExecute="SaveAs_CanExecute" Executed="SaveAs_Executed" Command="SaveAs"/>
    </Window.CommandBindings>
    <Window.DataContext>
        <viewmodels:MainWindowViewModel/>
    </Window.DataContext>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Открыть..." Command="Open"/>
                <MenuItem Header="_Сохранить" Command="Save"/>
                <MenuItem Header="Со_хранить как..." Command="SaveAs"/>
                <Separator/>
                <MenuItem Header="В_ыход" Click="ExitClick"/>
            </MenuItem>
        </Menu>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <DataGrid Margin="5" ItemsSource="{Binding Cards}" SelectedItem="{Binding SelectedCard}" SelectionChanged="DataGrid_SelectionChanged"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FIO}"/>
                    <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDateString}"/>
                    <DataGridTextColumn Header="Подразделение" Binding="{Binding Department}"/>
                    <DataGridTextColumn Header="Должность" Binding="{Binding Position}"/>
                    <DataGridTextColumn Header="Дата трудоустройства" Binding="{Binding EmploymentDateString}"/>
                    <DataGridTextColumn Header="Дата увольнения" Binding="{Binding DissimalDateString}"/>
                    <DataGridTextColumn Header="Оклад" Binding="{Binding SalaryText}"/>
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Создать" Padding="5" Margin="5" VerticalAlignment="Center" Click="CreateButton_Click"></Button>
                <Button Content="Правка" IsEnabled="{Binding IsEditButtonEnabled}" Padding="5" Margin="5" VerticalAlignment="Center"
                        Click="EditButton_Click"></Button>
                <Button Content="Удалить" IsEnabled="{Binding IsDeleteButtonEnabled}" Padding="5" Margin="5" VerticalAlignment="Center"
                        Click="DeleteButton_Click"></Button>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
