<Window x:Class="Calculator.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Calculator.WPF"
        xmlns:vm="clr-namespace:Calculator.WPF.ViewModels"
        mc:Ignorable="d"
        Title="Калькулятор" Height="450" Width="800" MinHeight="450" MinWidth="400" MaxHeight="450" MaxWidth="1200">
    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition Width=".5*"/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.ColumnSpan="6" TextAlignment="Right" Text="{Binding Result, Mode=OneWay}" FontSize="48" Background="Black" Foreground="Lime" Margin="10" Padding="10" VerticalAlignment="Center"/>
        <Button Grid.Row="2" Margin="10,10,5,5" Content="7" FontSize="36" VerticalAlignment="Center" Click="Digit_Button_Click"/>
        <Button Grid.Row="2" Grid.Column="1" Margin="5,10,5,5" Content="8" FontSize="36" VerticalAlignment="Center" Click="Digit_Button_Click"/>
        <Button Grid.Row="2" Grid.Column="2" Margin="5,10,10,5" Content="9" FontSize="36" VerticalAlignment="Center" Click="Digit_Button_Click"/>
        <Button Grid.Row="3" Margin="10,5,5,5" Content="4" FontSize="36" VerticalAlignment="Center" Click="Digit_Button_Click"/>
        <Button Grid.Row="3" Grid.Column="1" Margin="5,5,5,5" Content="5" FontSize="36" VerticalAlignment="Center" Click="Digit_Button_Click"/>
        <Button Grid.Row="3" Grid.Column="2" Margin="5,5,10,5" Content="6" FontSize="36" VerticalAlignment="Center" Click="Digit_Button_Click"/>
        <Button Grid.Row="4" Margin="10,5,5,5" Content="1" FontSize="36" VerticalAlignment="Center" Click="Digit_Button_Click"/>
        <Button Grid.Row="4" Grid.Column="1" Margin="5,5,5,5" Content="2" FontSize="36" VerticalAlignment="Center" Click="Digit_Button_Click"/>
        <Button Grid.Row="4" Grid.Column="2" Margin="5,5,10,5" Content="3" FontSize="36" VerticalAlignment="Center" Click="Digit_Button_Click"/>
        <Button Grid.Row="5" Margin="10,5,5,10" Content="0" FontSize="36" VerticalAlignment="Center" Click="Digit_Button_Click"/>
        <Button Grid.Row="2" Grid.Column="4" Grid.ColumnSpan="2" Margin="10,10,10,5" Content="C" FontSize="36" VerticalAlignment="Center" Click="ClearClick"/>
        <Button Grid.Row="3" Grid.Column="4" Margin="10,5,5,5" Content="+" FontSize="36" VerticalAlignment="Center" Click="OperationClick"/>
        <Button Grid.Row="3" Grid.Column="5" Margin="5,5,10,5" Content="-" FontSize="36" VerticalAlignment="Center" Click="OperationClick"/>
        <Button Grid.Row="4" Grid.Column="4" Margin="10,5,5,5" Content="*" FontSize="36" VerticalAlignment="Center" Click="OperationClick"/>
        <Button Grid.Row="4" Grid.Column="5" Margin="5,5,10,5" Content="/" FontSize="36" VerticalAlignment="Center" Click="OperationClick"/>
        <Button Grid.Row="5" Grid.Column="4" Grid.ColumnSpan="2" Margin="10,5,10,10" Content="=" FontSize="36" VerticalAlignment="Center" Click="OperationClick"/>
        <Button Grid.Row="5" Grid.Column="1"  Margin="5,5,5,10" Content="^" FontSize="36" VerticalAlignment="Center" Click="OperationClick"/>
        <Button Grid.Row="5" Grid.Column="2"  Margin="5,5,10,10" Content="%" FontSize="36" VerticalAlignment="Center" Click="PresentCLick"/>
        <Button Grid.Row="1"  Margin="10,5,5,10" Content="n^√" FontSize="36" VerticalAlignment="Center" Click="OperationClick"/>
        <Button Grid.Row="1" Grid.Column="1"  Margin="5,5,5,10" Content="sin" FontSize="36" VerticalAlignment="Center" Click="OperationClick"/>
        <Button Grid.Row="1" Grid.Column="2"  Margin="5,5,10,10" Content="√" FontSize="36" VerticalAlignment="Center" Click="OperationClick"/>
    </Grid>
</Window>
