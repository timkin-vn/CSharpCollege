<Window x:Class="CheckersGame.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CheckersGame.Wpf"
        xmlns:viewmodels="clr-namespace:CheckersGame.Wpf.ViewModels"
        xmlns:controls="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Шашки" 
        ResizeMode="NoResize"
        Width="600" Height="680"
        MinWidth="600" MinHeight="680"
        MaxWidth="600" MaxHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#F0E6D2">

    <Window.Resources>
        <controls:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="CellBackgroundStyle" TargetType="Rectangle">
            <Setter Property="Fill" Value="#8B5A2B"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDarkCell}" Value="True">
                    <Setter Property="Fill" Value="#F5DEB3"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsValidTarget}" Value="True">
                    <Setter Property="Fill" Value="#90EE90"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Stroke" Value="#FFD700"/>
                    <Setter Property="StrokeThickness" Value="4"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#DEB887" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding CurrentPlayerText}" FontSize="20" FontWeight="Bold" Foreground="#2F1E0E"/>
                <TextBlock Text="Шашки" FontSize="14" Foreground="#5C3D2E" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Игровая доска -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Cells}" HorizontalAlignment="Center" VerticalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid Width="560" Height="560">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Tag="{Binding}" MouseDown="Grid_MouseDown">
                        <!-- Фон клетки -->
                        <Rectangle Style="{StaticResource CellBackgroundStyle}"/>

                        <!-- Шашка -->
                        <Ellipse Width="60" Height="60" Visibility="{Binding HasPiece, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#1A1A1A"/>
                                    <Setter Property="Stroke" Value="#333333"/>
                                    <Setter Property="StrokeThickness" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasWhitePiece}" Value="True">
                                            <Setter Property="Fill" Value="#F0F0F0"/>
                                            <Setter Property="Stroke" Value="#888888"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsKing}" Value="True">
                                            <Setter Property="Stroke" Value="#FFD700"/>
                                            <Setter Property="StrokeThickness" Value="3"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#FFD700" BlurRadius="8" ShadowDepth="0"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <!-- Рамка для выбранной клетки -->
                        <Border IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BorderBrush" Value="Red"/>
                                            <Setter Property="BorderThickness" Value="3"/>
                                            <Setter Property="CornerRadius" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>

            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Grid.Row" Value="{Binding Row}"/>
                    <Setter Property="Grid.Column" Value="{Binding Column}"/>
                </Style>
            </ItemsControl.ItemContainerStyle>
        </ItemsControl>
    </Grid>
</Window>