<Window x:Class="TwentyFortyEight.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:TwentyFortyEight.Wpf.ViewModels"
        Title="2048"
        Height="680"
        Width="580"
        MinWidth="440"
        MinHeight="540"
        Background="#FAF8EF"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Window.DataContext>
        <viewmodels:MainWindowViewModel/>
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Title & Score row -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Game title -->
            <TextBlock Grid.Column="0"
                       Text="2048"
                       FontSize="48"
                       FontWeight="Bold"
                       Foreground="#776E65"/>

            <!-- Score boxes -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <Border Background="#BBADA0" CornerRadius="4" Padding="10,5" Margin="5,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="СЧЁТ" Foreground="#EEE4DA" FontSize="11"
                                   HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Score}" Foreground="White"
                                   FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="#BBADA0" CornerRadius="4" Padding="10,5" Margin="5,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="ЛУЧШАЯ" Foreground="#EEE4DA" FontSize="11"
                                   HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Text="{Binding BestTile}" Foreground="White"
                                   FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>

        <!-- Player & New Game row -->
        <Grid Grid.Row="1" Margin="0,8,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Игрок: " FontSize="16" Foreground="#776E65"/>
                <TextBlock Text="{Binding UserName}" FontSize="16"
                           FontWeight="Bold" Foreground="#776E65"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Новая игра"
                    Click="NewGameButton_Click"
                    Background="#8F7A66"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Padding="12,6"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#8F7A66"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="12,6"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#9F8B76"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Hint -->
        <TextBlock Grid.Row="2"
                   Text="Используйте стрелки ← ↑ → ↓ для перемещения плиток"
                   FontSize="12" Foreground="#776E65"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8"/>

        <!-- Game Board -->
        <Border Grid.Row="3"
                Background="#BBADA0"
                CornerRadius="6"
                Padding="8">

            <ItemsControl ItemsSource="{Binding Cells}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="4" Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="6"
                                CornerRadius="4"
                                Background="{Binding Background}">

                            <TextBlock Text="{Binding Text}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{Binding Foreground}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>
        </Border>

    </Grid>
</Window>
