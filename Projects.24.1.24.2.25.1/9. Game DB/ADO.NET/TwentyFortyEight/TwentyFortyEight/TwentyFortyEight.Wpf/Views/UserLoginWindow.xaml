<Window x:Class="TwentyFortyEight.Wpf.Views.UserLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:TwentyFortyEight.Wpf.ViewModels"
        Title="Добро пожаловать в 2048"
        Height="180" Width="340"
        MinHeight="180" MinWidth="340"
        MaxHeight="180" MaxWidth="340"
        WindowStartupLocation="CenterOwner"
        Background="#FAF8EF"
        ResizeMode="NoResize">

    <Window.DataContext>
        <viewmodels:UserLoginWindowViewModel />
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Введите имя игрока:"
                   FontSize="14"
                   Foreground="#776E65"
                   Margin="0,0,0,6"/>

        <TextBox Grid.Row="1"
                 Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                 FontSize="16"
                 Padding="6,4"
                 BorderBrush="#BBADA0"
                 Margin="0,0,0,10"
                 KeyDown="TextBox_KeyDown"/>

        <TextBlock Grid.Row="2"
                   Text="(Будет создан автоматически, если не существует)"
                   FontSize="11"
                   Foreground="#A0A0A0"
                   Margin="0,0,0,10"/>

        <Button Grid.Row="3"
                Content="Начать игру"
                Click="OkButton_Click"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Padding="16,8">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#8F7A66"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="4"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#9F8B76"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

    </Grid>
</Window>
