<Window x:Class="Calculator.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Calculator.Wpf" xmlns:viewmodels="clr-namespace:Calculator.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Калькулятор" Height="550" Width="400" MinHeight="500" MinWidth="350" MaxHeight="800" MaxWidth="600">
    <Window.DataContext>
        <viewmodels:MainWindowViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <!-- Дисплей -->
        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" 
                   Text="{Binding Result}" TextAlignment="Right"
                   FontSize="48" VerticalAlignment="Center" 
                   Background="Black" Foreground="LightGoldenrodYellow"
                   Margin="10" Padding="10" Height="80"/>

        <!-- Первый ряд кнопок -->
        <Button Grid.Row="1" Grid.Column="0" Margin="10,5,5,5" 
                Content="7" FontSize="28" Click="DigitButton_Click" />
        <Button Grid.Row="1" Grid.Column="1" Margin="5,5,5,5" 
                Content="8" FontSize="28" Click="DigitButton_Click" />
        <Button Grid.Row="1" Grid.Column="2" Margin="5,5,5,5" 
                Content="9" FontSize="28" Click="DigitButton_Click" />
        <Button Grid.Row="1" Grid.Column="3" Margin="5,5,10,5" 
                Content="C" FontSize="28" Background="LightCoral" Click="ClearButton_Click" />

        <!-- Второй ряд -->
        <Button Grid.Row="2" Grid.Column="0" Margin="10,5,5,5" 
                Content="4" FontSize="28" Click="DigitButton_Click" />
        <Button Grid.Row="2" Grid.Column="1" Margin="5,5,5,5" 
                Content="5" FontSize="28" Click="DigitButton_Click" />
        <Button Grid.Row="2" Grid.Column="2" Margin="5,5,5,5" 
                Content="6" FontSize="28" Click="DigitButton_Click" />
        <Button Grid.Row="2" Grid.Column="3" Margin="5,5,10,5" 
                Content="+" FontSize="28" Background="LightBlue" Click="OperationButton_Click" />

        <!-- Третий ряд -->
        <Button Grid.Row="3" Grid.Column="0" Margin="10,5,5,5" 
                Content="1" FontSize="28" Click="DigitButton_Click" />
        <Button Grid.Row="3" Grid.Column="1" Margin="5,5,5,5" 
                Content="2" FontSize="28" Click="DigitButton_Click" />
        <Button Grid.Row="3" Grid.Column="2" Margin="5,5,5,5" 
                Content="3" FontSize="28" Click="DigitButton_Click" />
        <Button Grid.Row="3" Grid.Column="3" Margin="5,5,10,5" 
                Content="-" FontSize="28" Background="LightBlue" Click="OperationButton_Click" />

        <!-- Четвертый ряд -->
        <Button Grid.Row="4" Grid.Column="0" Margin="10,5,5,5" 
                Content="0" FontSize="28" Click="DigitButton_Click" />
        <Button Grid.Row="4" Grid.Column="1" Margin="5,5,5,5" 
                Content="x²" FontSize="24" Background="LightGreen" Click="SquareButton_Click" />
        <Button Grid.Row="4" Grid.Column="2" Margin="5,5,5,5" 
                Content="√" FontSize="28" Background="LightGreen" Click="SquareRootButton_Click" />
        <Button Grid.Row="4" Grid.Column="3" Margin="5,5,10,5" 
                Content="*" FontSize="28" Background="LightBlue" Click="OperationButton_Click" />

        <!-- Пятый ряд -->
        <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" 
                Margin="10,5,5,10" Content="=" FontSize="28" 
                Background="LightSalmon" Click="OperationButton_Click" />
        <Button Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2" 
                Margin="5,5,10,10" Content="/" FontSize="28" 
                Background="LightBlue" Click="OperationButton_Click" />
    </Grid>
</Window>