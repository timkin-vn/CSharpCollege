<Window x:Class="Calculator.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:Calculator.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Калькулятор" Height="520" Width="820" MinHeight="520" MinWidth="820" MaxHeight="520" MaxWidth="1200"
        Background="#F2F2F2">
    <Window.DataContext>
        <viewmodels:MainWindowViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="CalcButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="36" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="MinHeight" Value="74" />
            <Setter Property="Background" Value="#E2E2E2" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="BorderBrush" Value="#8C8C8C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="CommandButtonStyle" TargetType="Button" BasedOn="{StaticResource CalcButtonStyle}">
            <Setter Property="FontSize" Value="34" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="110" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition Width="0.6*" />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="6" Background="Black" Margin="0" Padding="14">
            <TextBlock Text="{Binding Result}"
                       TextAlignment="Right"
                       FontSize="54"
                       FontFamily="Consolas"
                       VerticalAlignment="Center"
                       Foreground="Lime" />
        </Border>

        <Button Grid.Row="2" Grid.Column="0" Content="7" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click" />
        <Button Grid.Row="2" Grid.Column="1" Content="8" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click" />
        <Button Grid.Row="2" Grid.Column="2" Content="9" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click" />

        <Button Grid.Row="2" Grid.Column="4" Content="C" Style="{StaticResource CommandButtonStyle}" Click="ClearButton_Click" />
        <Button Grid.Row="2" Grid.Column="5" Content="√" Style="{StaticResource CommandButtonStyle}" ToolTip="Квадратный корень" Click="SquareRootButton_Click" />

        <Button Grid.Row="3" Grid.Column="0" Content="4" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click" />
        <Button Grid.Row="3" Grid.Column="1" Content="5" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click" />
        <Button Grid.Row="3" Grid.Column="2" Content="6" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click" />

        <Button Grid.Row="3" Grid.Column="4" Content="+" Style="{StaticResource CommandButtonStyle}" Click="OperationButton_Click" />
        <Button Grid.Row="3" Grid.Column="5" Content="-" Style="{StaticResource CommandButtonStyle}" Click="OperationButton_Click" />

        <Button Grid.Row="4" Grid.Column="0" Content="1" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click" />
        <Button Grid.Row="4" Grid.Column="1" Content="2" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click" />
        <Button Grid.Row="4" Grid.Column="2" Content="3" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click" />

        <Button Grid.Row="4" Grid.Column="4" Content="*" Style="{StaticResource CommandButtonStyle}" Click="OperationButton_Click" />
        <Button Grid.Row="4" Grid.Column="5" Content="/" Style="{StaticResource CommandButtonStyle}" Click="OperationButton_Click" />

        <Button Grid.Row="5" Grid.Column="0" Content="0" Style="{StaticResource CalcButtonStyle}" Click="DigitButton_Click" />
        <Button Grid.Row="5" Grid.Column="1" Content="," Style="{StaticResource CalcButtonStyle}" ToolTip="Дробная часть" Click="CommaButton_Click" />
        <Button Grid.Row="5" Grid.Column="2" Content="x²" Style="{StaticResource CalcButtonStyle}" ToolTip="Возведение в квадрат" Click="SquareButton_Click" />

        <Button Grid.Row="5" Grid.Column="4" Grid.ColumnSpan="2" Content="=" Style="{StaticResource CommandButtonStyle}" Click="EqualButton_Click" />
    </Grid>
</Window>
