<Window x:Class="CalculatorWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" 
        Height="500" Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="Black" 
                CornerRadius="5" 
                Margin="0,0,0,10"
                Height="80">
            <TextBlock x:Name="DisplayLabel" 
                       Text="0" 
                       Foreground="LimeGreen" 
                       FontSize="36" 
                       FontFamily="Consolas"
                       HorizontalAlignment="Right" 
                       VerticalAlignment="Center" 
                       Margin="10"/>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="Btn7" Grid.Row="0" Grid.Column="0" Content="7" Click="DigitButton_Click" Style="{StaticResource CalculatorButton}"/>
            <Button x:Name="Btn8" Grid.Row="0" Grid.Column="1" Content="8" Click="DigitButton_Click" Style="{StaticResource CalculatorButton}"/>
            <Button x:Name="Btn9" Grid.Row="0" Grid.Column="2" Content="9" Click="DigitButton_Click" Style="{StaticResource CalculatorButton}"/>
            <Button x:Name="BtnClear" Grid.Row="0" Grid.Column="3" Content="C" Click="ClearButton_Click" Style="{StaticResource OperationButton}"/>

            <Button x:Name="Btn4" Grid.Row="1" Grid.Column="0" Content="4" Click="DigitButton_Click" Style="{StaticResource CalculatorButton}"/>
            <Button x:Name="Btn5" Grid.Row="1" Grid.Column="1" Content="5" Click="DigitButton_Click" Style="{StaticResource CalculatorButton}"/>
            <Button x:Name="Btn6" Grid.Row="1" Grid.Column="2" Content="6" Click="DigitButton_Click" Style="{StaticResource CalculatorButton}"/>
            <Button x:Name="BtnMultiply" Grid.Row="1" Grid.Column="3" Content="*" Click="OperationButton_Click" Style="{StaticResource OperationButton}"/>

            <Button x:Name="Btn1" Grid.Row="2" Grid.Column="0" Content="1" Click="DigitButton_Click" Style="{StaticResource CalculatorButton}"/>
            <Button x:Name="Btn2" Grid.Row="2" Grid.Column="1" Content="2" Click="DigitButton_Click" Style="{StaticResource CalculatorButton}"/>
            <Button x:Name="Btn3" Grid.Row="2" Grid.Column="2" Content="3" Click="DigitButton_Click" Style="{StaticResource CalculatorButton}"/>
            <Button x:Name="BtnDivide" Grid.Row="2" Grid.Column="3" Content="/" Click="OperationButton_Click" Style="{StaticResource OperationButton}"/>

            <Button x:Name="Btn0" Grid.Row="3" Grid.Column="0" Content="0" Click="DigitButton_Click" Style="{StaticResource CalculatorButton}"/>
            <Button x:Name="BtnComma" Grid.Row="3" Grid.Column="1" Content="," Click="CommaButton_Click" Style="{StaticResource CalculatorButton}"/>
            <Button x:Name="BtnSquare" Grid.Row="3" Grid.Column="2" Content="x²" Click="SquareButton_Click" Style="{StaticResource CalculatorButton}"/>
            <Button x:Name="BtnSubtract" Grid.Row="3" Grid.Column="3" Content="-" Click="OperationButton_Click" Style="{StaticResource OperationButton}"/>

            <Button x:Name="BtnAdd" Grid.Row="4" Grid.Column="2" Content="+" Click="OperationButton_Click" Style="{StaticResource OperationButton}"/>
            <Button x:Name="BtnEqual" Grid.Row="4" Grid.Column="3" Content="=" Click="EqualButton_Click" Style="{StaticResource OperationButton}"/>
        </Grid>
    </Grid>
</Window>