<Window x:Class="CardFile.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.Wpf" 
        xmlns:viewmodels="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="450" Width="850" 
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" 
        Initialized="Window_Initialized">
    <Window.DataContext>
        <viewmodels:MainWindowViewModel />
    </Window.DataContext>

    <DockPanel>
        <!-- Главное меню -->
        <Menu DockPanel.Dock="Top" Background="#F0F0F0" Padding="2">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Открыть..." Click="FileOpenMenuItem_Click" />
                <MenuItem Header="_Сохранить" Click="FileSaveMenuItem_Click" />
                <MenuItem Header="Со_хранить как..." Click="FileSaveAsMenuItem_Click" />
                <Separator />
                <MenuItem Header="В_ыход" Click="FileExitMenuItem_Click" />
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Таблица вывода фильмов -->
            <DataGrid Grid.Row="0" 
                      ItemsSource="{Binding Cards}" 
                      SelectedItem="{Binding SelectedCard, Mode=TwoWay}" 
                      SelectionChanged="DataGrid_SelectionChanged"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      CanUserAddRows="False" 
                      SelectionMode="Single" 
                      Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                    <DataGridTextColumn Header="Название фильма" Binding="{Binding Title}" Width="2*" />
                    <DataGridTextColumn Header="Режиссер" Binding="{Binding Director}" Width="1.5*" />
                    <DataGridTextColumn Header="Год выпуска" Binding="{Binding Year}" Width="90" />
                    <DataGridTextColumn Header="Жанр" Binding="{Binding Genre}" Width="120" />
                    <DataGridTextColumn Header="Длительность" Binding="{Binding DurationText}" Width="110" />
                    <DataGridTextColumn Header="Рейтинг" Binding="{Binding RatingText}" Width="70" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Нижняя панель кнопок -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                <Button Content="Создать" Padding="10,4" Margin="5" VerticalAlignment="Center" Click="CreateButton_Click" />
                <Button Content="Правка" IsEnabled="{Binding IsEditButtonEnabled}" Padding="10,4" Margin="5" VerticalAlignment="Center" 
                        Click="EditButton_Click" />
                <Button Content="Удалить" IsEnabled="{Binding IsDeleteButtonEnabled}" Padding="10,4" Margin="5" VerticalAlignment="Center" 
                        Click="DeleteButton_Click" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
