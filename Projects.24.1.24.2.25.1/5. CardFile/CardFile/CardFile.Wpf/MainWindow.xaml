<Window x:Class="CardFile.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" 
        Height="550" Width="900"
        Loaded="Window_Loaded">
    <Window.DataContext>
        <local:MainWindowViewModel />
    </Window.DataContext>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Создать" Click="NewFile_Click" />
                <MenuItem Header="Открыть..." Click="OpenFile_Click" />
                <MenuItem Header="Сохранить" Click="SaveFile_Click" />
                <MenuItem Header="Сохранить как..." Click="SaveAsFile_Click" />
                <Separator />
                <MenuItem Header="Выход" Click="Exit_Click" />
            </MenuItem>
        </Menu>

        <ToolBar DockPanel.Dock="Top">
            <Button Content="Добавить" Click="AddCard" ToolTip="Добавить игрока" />
            <Button Content="Изменить" IsEnabled="{Binding IsEditButtonEnabled}" Click="EditCard" ToolTip="Редактировать выбранного игрока" />
            <Button Content="Удалить" IsEnabled="{Binding IsDeleteButtonEnabled}" Click="DeleteCard" ToolTip="Удалить выбранного игрока" />
        </ToolBar>

        <DataGrid ItemsSource="{Binding Cards}" 
                  SelectedItem="{Binding SelectedCard, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                <DataGridTextColumn Header="Никнейм" Binding="{Binding Nickname}" Width="120" />
                <DataGridTextColumn Header="Реальное имя" Binding="{Binding RealName}" Width="150" />
                <DataGridTextColumn Header="Страна" Binding="{Binding Country}" Width="100" />
                <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDateText}" Width="100" />
                <DataGridTextColumn Header="Команда" Binding="{Binding Team}" Width="120" />
                <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="100" />
                <DataGridTextColumn Header="Призовые ($)" Binding="{Binding EarningsText}" Width="120" />
                <DataGridTextColumn Header="Достижения" Binding="{Binding Achievements}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>