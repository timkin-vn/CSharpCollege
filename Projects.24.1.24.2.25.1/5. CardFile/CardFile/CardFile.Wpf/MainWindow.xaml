<Window x:Class="CardFile.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.Wpf" xmlns:viewmodels="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="450" Width="800" Loaded="Window_Loaded" Initialized="Window_Initialized">
    <Window.DataContext>
        <viewmodels:MainWindowViewModel />
    </Window.DataContext>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Открыть..." Click="FileOpenMenuItem_Click" />
                <MenuItem Header="_Сохранить" Click="FileSaveMenuItem_Click" />
                <MenuItem Header="Со_хранить как..." Click="FileSaveAsMenuItem_Click" />
                <Separator />
                <MenuItem Header="В_ыход" Click="FileExitMenuItem_Click" />
            </MenuItem>
        </Menu>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid ItemsSource="{Binding Cards}" 
          SelectedItem="{Binding SelectedCard}" 
          SelectionChanged="DataGrid_SelectionChanged"
          AutoGenerateColumns="False" 
          IsReadOnly="True"
          CanUserAddRows="False" 
          SelectionMode="Single" 
          Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*" />
                    <DataGridTextColumn Header="Жанр" Binding="{Binding Genre}" Width="150" />
                    <DataGridTextColumn Header="Рейтинг" Binding="{Binding GlobalRating}" Width="80" />
                    <DataGridTextColumn Header="Моя оценка" Binding="{Binding MyScore}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                <!-- Кнопка создания новой записи -->
                <Button Content="Создать" 
            Width="100" Padding="5" Margin="5" 
            Click="CreateButton_Click" />

                <!-- Кнопка редактирования (активна только при выборе строки) -->
                <Button Content="Правка" 
            Width="100" Padding="5" Margin="5" 
            Click="EditButton_Click" 
            IsEnabled="{Binding IsEditButtonEnabled}" />

                <!-- Кнопка удаления -->
                <Button Content="Удалить" 
            Width="100" Padding="5" Margin="5" 
            Click="DeleteButton_Click" 
            IsEnabled="{Binding IsDeleteButtonEnabled}" />
            </StackPanel>

        </Grid>
    </DockPanel>
</Window>
