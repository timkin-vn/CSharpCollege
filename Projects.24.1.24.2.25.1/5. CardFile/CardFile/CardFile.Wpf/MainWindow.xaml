<Window x:Class="CardFile.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.Wpf"
        xmlns:viewmodels="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="450" Width="950"
        Loaded="Window_Loaded" Initialized="Window_Initialized">
    <Window.DataContext>
        <viewmodels:MainWindowViewModel />
    </Window.DataContext>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Открыть..." Click="FileOpenMenuItem_Click" />
                <MenuItem Header="_Сохранить" Click="FileSaveMenuItem_Click" />
                <MenuItem Header="Со_хранить как..." Click="FileSaveAsMenuItem_Click" />
                <Separator />
                <MenuItem Header="В_ыход" Click="FileExitMenuItem_Click" />
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0"
                      ItemsSource="{Binding Cards}"
                      SelectedItem="{Binding SelectedCard}"
                      SelectionChanged="DataGrid_SelectionChanged"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Заголовок" Binding="{Binding Title}" Width="180" />
                    <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="130" />
                    <DataGridTextColumn Header="Текст" Binding="{Binding ShortText}" Width="250" />
                    <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAtText}" Width="130" />
                    <DataGridTextColumn Header="Выполнено" Binding="{Binding DoneText}" Width="110" />
                    <DataGridTextColumn Header="Закреплено" Binding="{Binding PinnedText}" Width="110" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Создать" Padding="5" Margin="5" VerticalAlignment="Center" Click="CreateButton_Click" />
                <Button Content="Правка"
                        IsEnabled="{Binding IsEditButtonEnabled}"
                        Padding="5" Margin="5" VerticalAlignment="Center"
                        Click="EditButton_Click" />
                <Button Content="Удалить"
                        IsEnabled="{Binding IsDeleteButtonEnabled}"
                        Padding="5" Margin="5" VerticalAlignment="Center"
                        Click="DeleteButton_Click" />
                <Button Content="{Binding ToggleDoneButtonText}"
                        IsEnabled="{Binding IsToggleDoneButtonEnabled}"
                        Padding="5" Margin="5" VerticalAlignment="Center"
                        Click="ToggleDoneButton_Click" />
                <Button Content="{Binding TogglePinnedButtonText}"
                        IsEnabled="{Binding IsTogglePinnedButtonEnabled}"
                        Padding="5" Margin="5" VerticalAlignment="Center"
                        Click="TogglePinnedButton_Click" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>