<Window x:Class="CardFile.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.Wpf" xmlns:viewmodels="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="450" Width="1100" Loaded="Window_Loaded" Initialized="Window_Initialized"
        Background="#1E1E1E" Foreground="#FFFFFF">
    <Window.DataContext>
        <viewmodels:MainWindowViewModel />
    </Window.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="Bg" Color="#1E1E1E" />
        <SolidColorBrush x:Key="Surface" Color="#252526" />
        <SolidColorBrush x:Key="Surface2" Color="#2D2D30" />
        <SolidColorBrush x:Key="Border" Color="#3F3F46" />
        <SolidColorBrush x:Key="Text" Color="#FFFFFF" />
        <SolidColorBrush x:Key="Selection" Color="#264F78" />

        <Style TargetType="{x:Type Menu}">
            <Setter Property="Background" Value="{StaticResource Bg}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
        </Style>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Background" Value="{StaticResource Bg}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource Surface2}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="{StaticResource Surface}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Border}" />
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource Border}" />
            <Setter Property="RowBackground" Value="{StaticResource Surface}" />
            <Setter Property="AlternatingRowBackground" Value="#2A2A2D" />
        </Style>

        <Style TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="{StaticResource Surface}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Selection}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Selection}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{StaticResource Bg}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Открыть..." Click="FileOpenMenuItem_Click" />
                <MenuItem Header="_Сохранить" Click="FileSaveMenuItem_Click" />
                <MenuItem Header="Со_хранить как..." Click="FileSaveAsMenuItem_Click" />
                <Separator />
                <MenuItem Header="В_ыход" Click="FileExitMenuItem_Click" />
            </MenuItem>
        </Menu>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0" ItemsSource="{Binding Cards}" SelectedItem="{Binding SelectedCard}" SelectionChanged="DataGrid_SelectionChanged"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" SelectionMode="Single" Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Герой" Binding="{Binding Hero}" />
                    <DataGridTextColumn Header="Слот 1" Binding="{Binding Slot1}" />
                    <DataGridTextColumn Header="Слот 2" Binding="{Binding Slot2}" />
                    <DataGridTextColumn Header="Слот 3" Binding="{Binding Slot3}" />
                    <DataGridTextColumn Header="Слот 4" Binding="{Binding Slot4}" />
                    <DataGridTextColumn Header="Слот 5" Binding="{Binding Slot5}" />
                    <DataGridTextColumn Header="Слот 6" Binding="{Binding Slot6}" />
                    <DataGridTextColumn Header="Нейтралка" Binding="{Binding Neutral}" />
                </DataGrid.Columns>
            </DataGrid>
            
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Создать" Padding="5" Margin="5" VerticalAlignment="Center" Click="CreateButton_Click" />
                <Button Content="Правка" IsEnabled="{Binding IsEditButtonEnabled}" Padding="5" Margin="5" VerticalAlignment="Center" 
                        Click="EditButton_Click" />
                <Button Content="Удалить" IsEnabled="{Binding IsDeleteButtonEnabled}" Padding="5" Margin="5" VerticalAlignment="Center" 
                        Click="DeleteButton_Click" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
