<Window x:Class="CardFile.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.Wpf" xmlns:viewmodels="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="450" Width="800" Loaded="Window_Loaded" Initialized="Window_Initialized"
        Background="#1E1E1E"
        Foreground="#FFFFFF">

    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        

        <Style TargetType="Button">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#555555"/>

        </Style>

        
        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>

        </Style>

        
    </Window.Resources>
    
    
    <Window.DataContext>
        <viewmodels:MainWindowViewModel />
    </Window.DataContext>
    
    

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Открыть..." Click="FileOpenMenuItem_Click" />
                <MenuItem Header="_Сохранить" Click="FileSaveMenuItem_Click" />
                <MenuItem Header="Со_хранить как..." Click="FileSaveAsMenuItem_Click" />
                <Separator />
                <MenuItem Header="В_ыход" Click="FileExitMenuItem_Click" />
            </MenuItem>
        </Menu>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0" ItemsSource="{Binding Cards}" SelectedItem="{Binding SelectedCard}" SelectionChanged="DataGrid_SelectionChanged"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" SelectionMode="Single" Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding Fio}" />
                    <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDateText}" />
                    <DataGridTextColumn Header="Команда" Binding="{Binding Department}" />
                    <DataGridTextColumn Header="Роль" Binding="{Binding Position}" />
                    <DataGridTextColumn Header="Начало карьеры" Binding="{Binding EmploymentDateText}" />
                    <DataGridTextColumn Header="конец карьеры" Binding="{Binding DismissalDateText}" />
                    <DataGridTextColumn Header="рейтинг HLTV" Binding="{Binding SalaryText}" />
                </DataGrid.Columns>
            </DataGrid>
            
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Создать" Padding="5" Margin="5" VerticalAlignment="Center" Click="CreateButton_Click" />
                <Button Content="Правка" IsEnabled="{Binding IsEditButtonEnabled}" Padding="5" Margin="5" VerticalAlignment="Center" 
                        Click="EditButton_Click" />
                <Button Content="Удалить" IsEnabled="{Binding IsDeleteButtonEnabled}" Padding="5" Margin="5" VerticalAlignment="Center" 
                        Click="DeleteButton_Click" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
