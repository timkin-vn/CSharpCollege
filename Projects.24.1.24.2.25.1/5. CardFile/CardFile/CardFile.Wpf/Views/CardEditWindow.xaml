<Window x:Class="CardFile.Wpf.Views.CardEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.Wpf.Views"
        xmlns:viewmodels="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Правка данных автомобиля" Height="450" Width="500" ResizeMode="NoResize">
	<Window.DataContext>
		<viewmodels:CardViewModel />
	</Window.DataContext>

	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition />
		</Grid.ColumnDefinitions>

		<TextBlock Grid.Row="0" Grid.Column="0" Text="Марка:" VerticalAlignment="Center" Margin="5" />
		<TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Brand}" VerticalAlignment="Center" Margin="5" />

		<TextBlock Grid.Row="1" Grid.Column="0" Text="Модель:" VerticalAlignment="Center" Margin="5" />
		<TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Model}" VerticalAlignment="Center" Margin="5" />

		<TextBlock Grid.Row="2" Grid.Column="0" Text="Цвет:" VerticalAlignment="Center" Margin="5" />
		<TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Color}" VerticalAlignment="Center" Margin="5" />

		<TextBlock Grid.Row="3" Grid.Column="0" Text="Дата выпуска:" VerticalAlignment="Center" Margin="5" />
		<DatePicker Grid.Row="3" Grid.Column="1" SelectedDate="{Binding ReleaseDate}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />

		<TextBlock Grid.Row="4" Grid.Column="0" Text="Тип кузова:" VerticalAlignment="Center" Margin="5" />
		<TextBox Grid.Row="4" Grid.Column="1" Text="{Binding BodyType}" VerticalAlignment="Center" Margin="5" />

		<TextBlock Grid.Row="5" Grid.Column="0" Text="Комплектация:" VerticalAlignment="Center" Margin="5" />
		<TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Configuration}" VerticalAlignment="Center" Margin="5" />

		<TextBlock Grid.Row="6" Grid.Column="0" Text="Дата поступления:" VerticalAlignment="Center" Margin="5" />
		<DatePicker Grid.Row="6" Grid.Column="1" SelectedDate="{Binding ArrivalDate}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5" />

		<TextBlock Grid.Row="7" Grid.Column="0" Text="Дата продажи:" VerticalAlignment="Center" Margin="5" />
		<StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
			<DatePicker SelectedDate="{Binding SaleDate}" IsEnabled="{Binding IsSaleDateEnabled}" VerticalAlignment="Center" Margin="5" />
			<CheckBox VerticalAlignment="Center" IsChecked="{Binding IsInStock}" Margin="5"
                      Checked="IsInStockCheckBox_Checked"
                      Unchecked="IsInStockCheckBox_Unchecked">
				<TextBlock Text="В наличии" VerticalAlignment="Center" />
			</CheckBox>
		</StackPanel>

		<TextBlock Grid.Row="8" Grid.Column="0" Text="Цена:" VerticalAlignment="Center" Margin="5" />
		<TextBox Grid.Row="8" Grid.Column="1" Text="{Binding Price}" VerticalAlignment="Center" HorizontalAlignment="Left" Width="150" Margin="5" />

		<StackPanel Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right">
			<Button Content="Сохранить" Width="80" Padding="5" Margin="5" Click="OkButton_Click" />
			<Button Content="Отмена" Width="80" Padding="5" Margin="5" Click="CancelButton_Click" />
		</StackPanel>
	</Grid>
</Window>