<Window x:Class="CardFile.Wpf.Views.CardEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.Wpf.Views" 
        xmlns:viewmodels="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Правка карточки" Height="350" Width="450" ResizeMode="NoResize">

    <Window.DataContext>
        <viewmodels:CardViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- 0: Название -->
            <RowDefinition Height="Auto" />
            <!-- 1: Жанр -->
            <RowDefinition Height="Auto" />
            <!-- 2: Мировой рейтинг -->
            <RowDefinition Height="Auto" />
            <!-- 3: Личная оценка -->
            <RowDefinition Height="Auto" />
            <!-- 4: Дата выхода -->
            <RowDefinition Height="*" />
            <!-- 5: Кнопки -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Название -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" Margin="5" VerticalAlignment="Center" />
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Title}" Margin="5" Width="250" HorizontalAlignment="Left" />

        <!-- Жанр -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Жанр:" Margin="5" VerticalAlignment="Center" />
        <ComboBox Grid.Row="1" Grid.Column="1" Text="{Binding Genre}" IsEditable="True" Margin="5" Width="200" HorizontalAlignment="Left">
            <ComboBoxItem Content="Экшен" />
            <ComboBoxItem Content="RPG" />
            <ComboBoxItem Content="Драма" />
            <ComboBoxItem Content="Стратегия" />
        </ComboBox>

        <!-- Мировой рейтинг -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Рейтинг (IMDB):" Margin="5" VerticalAlignment="Center" />
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding GlobalRating}" Margin="5" Width="100" HorizontalAlignment="Left" />

        <!-- Личная оценка -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Моя оценка (1-10):" Margin="5" VerticalAlignment="Center" />
        <Slider Grid.Row="3" Grid.Column="1" Value="{Binding MyScore}" Minimum="1" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True" Margin="5" Width="200" HorizontalAlignment="Left" />
        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MyScore}" HorizontalAlignment="Right" Margin="0,5,60,5" VerticalAlignment="Center" FontWeight="Bold" />

        <!-- Дата выхода -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Дата выхода:" Margin="5" VerticalAlignment="Center" />
        <DatePicker Grid.Row="4" Grid.Column="1" SelectedDate="{Binding ReleaseDate}" Margin="5" HorizontalAlignment="Left" />

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right">
            <Button Content="Сохранить" Padding="15,5" Margin="5" Click="OkButton_Click" IsDefault="True" />
            <Button Content="Отмена" Padding="15,5" Margin="5" Click="CancelButton_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
