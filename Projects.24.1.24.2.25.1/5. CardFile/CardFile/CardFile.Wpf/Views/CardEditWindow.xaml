<Window x:Class="CardFile.Wpf.Views.CardEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.Wpf.Views" 
        xmlns:viewmodels="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Редактирование товара" Height="400" Width="500" ResizeMode="NoResize">
    <Window.DataContext>
        <viewmodels:CardViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Наименование:" Margin="5" />
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ProductName}" Margin="5" Width="250" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Модель:" Margin="5" />
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ProductModel}" Margin="5" Width="250" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Цвет:" Margin="5" />
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ProductColor}" Margin="5" Width="250" />

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата производства:" Margin="5" />
        <DatePicker Grid.Row="3" Grid.Column="1" SelectedDate="{Binding ManufactureDate}" Margin="5" Width="150" />

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Категория:" Margin="5" />
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Category}" Margin="5" Width="250" />

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Производитель:" Margin="5" />
        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Manufacturer}" Margin="5" Width="250" />

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Дата поступления:" Margin="5" />
        <DatePicker Grid.Row="6" Grid.Column="1" SelectedDate="{Binding ReceiptDate}" Margin="5" Width="150" />

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Дата списания:" Margin="5" />
        <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
            <DatePicker SelectedDate="{Binding WriteOffDate}" 
                        IsEnabled="{Binding IsWriteOffDateEnabled}" 
                        Margin="5" Width="150" />
            <CheckBox VerticalAlignment="Center" IsChecked="{Binding IsNotWrittenOff}" Margin="5">
                <TextBlock Text="Не списано" VerticalAlignment="Center" />
            </CheckBox>
        </StackPanel>

        <TextBlock Grid.Row="8" Grid.Column="0" Text="Цена:" Margin="5" />
        <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding Price}" Margin="5" Width="250" />

        <StackPanel Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Padding="5" Margin="5" Click="OkButton_Click" />
            <Button Content="Отмена" Padding="5" Margin="5" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>