<Window x:Class="Game2048.Wpf.UserLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Game2048.Wpf"
        Title="Регистрация участника"
        Height="190" Width="350"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F5"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <local:UserLoginWindowViewModel />
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="Идентификатор (Имя) игрока:"
                   FontSize="13"
                   Foreground="#1E5631"
                   FontWeight="SemiBold"
                   Margin="0,0,0,5"/>

        <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                 Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                 FontSize="14"
                 Padding="6"
                 Background="White"
                 BorderBrush="#27AE60"
                 BorderThickness="1.5"
                 Margin="0,0,0,8">
            <TextBox.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </TextBox.Resources>
        </TextBox>

        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="Профиль будет создан автоматически при его отсутствии"
                   FontSize="11"
                   FontStyle="Italic"
                   Foreground="#7F8C8D"
                   Margin="2,0,0,0"/>

        <Button Grid.Row="3" Grid.Column="1"
                Content="Запустить сессию"
                Click="OnLoginClick"
                Padding="15,0"
                Height="35"
                VerticalAlignment="Bottom"
                Cursor="Hand">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#27AE60"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1E5631"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>