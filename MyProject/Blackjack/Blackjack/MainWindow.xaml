<Window x:Class="BlackjackGame.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:BlackjackGame.Wpf.ViewModels"
        Title="Игра 21" Height="600" Width="800"
        Background="#2E8B57">
    <!-- Зеленый фон стола -->

    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->
            <RowDefinition Height="*"/>
            <!-- Зона дилера -->
            <RowDefinition Height="Auto"/>
            <!-- Разделитель -->
            <RowDefinition Height="*"/>
            <!-- Зона игрока -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопки -->
        </Grid.RowDefinitions>

        <!-- Сообщение о статусе -->
        <TextBlock Grid.Row="0" Text="{Binding Message}" 
                   FontSize="24" Foreground="White" 
                   HorizontalAlignment="Center" Margin="0,10"/>

        <!-- Карты Дилера -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="Дилер" Foreground="White" FontSize="18" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding DealerScore, StringFormat='Очки: {0}'}" 
                       Foreground="White" FontSize="16" HorizontalAlignment="Center" Margin="0,5"/>

            <ItemsControl ItemsSource="{Binding DealerHand}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="60" Height="90" Background="White" CornerRadius="5" 
                                Margin="5" BorderBrush="Black" BorderThickness="1">
                            <TextBlock Text="{Binding ShortName}" 
                                       Foreground="{Binding Color}"
                                       FontSize="18" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <Rectangle Grid.Row="2" Height="2" Fill="White" Margin="0,10"/>

        <!-- Карты Игрока -->
        <StackPanel Grid.Row="3" VerticalAlignment="Center">
            <TextBlock Text="Игрок" Foreground="White" FontSize="18" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding PlayerScore, StringFormat='Очки: {0}'}" 
                       Foreground="White" FontSize="16" HorizontalAlignment="Center" Margin="0,5"/>

            <ItemsControl ItemsSource="{Binding PlayerHand}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="60" Height="90" Background="White" CornerRadius="5" 
                                Margin="5" BorderBrush="Black" BorderThickness="1">
                            <TextBlock Text="{Binding ShortName}" 
                                       Foreground="{Binding Color}"
                                       FontSize="18" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button Content="Взять карту" Width="120" Height="40" Margin="10" 
                    Command="{Binding HitCommand}" FontSize="14"/>
            <Button Content="Хватит" Width="120" Height="40" Margin="10" 
                    Command="{Binding StandCommand}" FontSize="14"/>
            <Button Content="Новая игра" Width="120" Height="40" Margin="10" 
                    Command="{Binding NewGameCommand}" FontSize="14" Background="LightGray"/>
        </StackPanel>
    </Grid>
</Window>
    