<Window x:Class="CardFile.Wpf.Views.CardEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.Wpf.Views"
        xmlns:viewmodels="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Карточка морга" Height="550" Width="500" ResizeMode="NoResize">

    <Window.DataContext>
        <viewmodels:CardViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Фамилия:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding LastName}" Margin="5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Имя:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FirstName}" Margin="5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Отчество:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MiddleName}" Margin="5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата рождения:" Margin="5" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="3" Grid.Column="1" SelectedDate="{Binding BirthDate}" Margin="5"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Дата смерти:" Margin="5" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="4" Grid.Column="1" SelectedDate="{Binding DeathDate}" Margin="5"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Причина смерти:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding CauseOfDeath}" Margin="5"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Место обнаружения:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding PlaceOfDeath}" Margin="5"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Дата поступления:" Margin="5" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="7" Grid.Column="1" SelectedDate="{Binding AdmissionDate}" Margin="5"/>

        <TextBlock Grid.Row="8" Grid.Column="0" Text="Номер секции:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding SectionNumber}" Margin="5"/>

        <CheckBox Grid.Row="9" Grid.Column="1" Content="Выдан родственникам"
                  IsChecked="{Binding IsReleased}" Margin="5"/>

        <StackPanel Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="5">
            <Button Content="OK" Padding="8,4" Margin="5" Click="OkButton_Click"/>
            <Button Content="Отмена" Padding="8,4" Margin="5" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>