<Window x:Class="CardFile.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.Wpf"
        xmlns:viewmodels="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="600" Width="1200"
        Loaded="Window_Loaded" Initialized="Window_Initialized">

    <Window.DataContext>
        <viewmodels:MainWindowViewModel />
    </Window.DataContext>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Открыть..." Click="FileOpenMenuItem_Click" />
                <MenuItem Header="_Сохранить" Click="FileSaveMenuItem_Click" />
                <MenuItem Header="Со_хранить как..." Click="FileSaveAsMenuItem_Click" />
                <Separator />
                <MenuItem Header="В_ыход" Click="FileExitMenuItem_Click" />
            </MenuItem>
        </Menu>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="220" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,15,0"/>

            <TextBlock Text="Фильтр:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox Width="180" SelectedItem="{Binding SelectedFilter}" Margin="0,0,15,0">
                <ComboBoxItem Content="Все записи"/>
                <ComboBoxItem Content="Только в морге"/>
                <ComboBoxItem Content="Только выданные"/>
                <ComboBoxItem Content="Поступившие сегодня"/>
            </ComboBox>

            <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox Width="180" SelectedItem="{Binding SelectedSort}">
                <ComboBoxItem Content="По ФИО"/>
                <ComboBoxItem Content="По дате смерти"/>
                <ComboBoxItem Content="По дате поступления"/>
                <ComboBoxItem Content="По секции"/>
            </ComboBox>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0"
                      ItemsSource="{Binding FilteredCards}"
                      SelectedItem="{Binding SelectedCard}"
                      SelectionChanged="DataGrid_SelectionChanged"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      Margin="5">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding Fio}" Width="200"/>
                    <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDateText}" Width="110"/>
                    <DataGridTextColumn Header="Дата смерти" Binding="{Binding DeathDateText}" Width="110"/>
                    <DataGridTextColumn Header="Причина смерти" Binding="{Binding CauseOfDeath}" Width="180"/>
                    <DataGridTextColumn Header="Место обнаружения" Binding="{Binding PlaceOfDeath}" Width="160"/>
                    <DataGridTextColumn Header="Дата поступления" Binding="{Binding AdmissionDateText}" Width="130"/>
                    <DataGridTextColumn Header="Номер секции" Binding="{Binding SectionNumber}" Width="110"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusText}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Создать" Padding="5" Margin="5" VerticalAlignment="Center" Click="CreateButton_Click" />
                <Button Content="Правка" IsEnabled="{Binding IsEditButtonEnabled}" Padding="5" Margin="5" VerticalAlignment="Center"
                        Click="EditButton_Click" />
                <Button Content="Удалить" IsEnabled="{Binding IsDeleteButtonEnabled}" Padding="5" Margin="5" VerticalAlignment="Center"
                        Click="DeleteButton_Click" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>