<Window x:Class="FifteenGame.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:FifteenGame.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Змейка" Height="650" Width="850"
        MinHeight="500" MinWidth="700"
        KeyDown="Window_KeyDown">

	<Window.DataContext>
		<viewmodels:MainWindowViewModel />
	</Window.DataContext>

	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<Border Grid.Row="0" Background="LightGray" Margin="0,0,0,10" Padding="10" CornerRadius="5">
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
				<TextBlock Text="Счёт: " FontSize="24" FontWeight="Bold"/>
				<TextBlock Text="{Binding Score}" FontSize="24" FontWeight="Bold" Foreground="Green"/>
				<TextBlock Text="   |   " FontSize="24"/>
				<TextBlock Text="{Binding GameStatus}" FontSize="18" Foreground="Red" FontWeight="Bold"/>
				<Button Content="🔄 Новая игра" Command="{Binding NewGameCommand}" 
                        Margin="30,0,0,0" Padding="15,8" Background="LightGreen" 
                        FontWeight="Bold" FontSize="16" BorderBrush="Green" BorderThickness="2"
                        Cursor="Hand"/>
			</StackPanel>
		</Border>


		<Border Grid.Row="1" BorderBrush="Black" BorderThickness="3" CornerRadius="5" Background="LightYellow">
			<ItemsControl x:Name="GameBoard" ItemsSource="{Binding Cells}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<UniformGrid Rows="15" Columns="20" Background="LightYellow"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Margin="1" BorderBrush="Gray" BorderThickness="0.5">
							<Border.Style>
								<Style TargetType="Border">
									<Style.Triggers>
										<DataTrigger Binding="{Binding Type}" Value="Snake">
											<Setter Property="Background" Value="ForestGreen"/>
										</DataTrigger>
										<DataTrigger Binding="{Binding Type}" Value="Food">
											<Setter Property="Background" Value="Red"/>
										</DataTrigger>
										<DataTrigger Binding="{Binding Type}" Value="Empty">
											<Setter Property="Background" Value="LightYellow"/>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</Border.Style>

							<TextBlock Text="{Binding Text}" FontSize="20" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="Segoe UI Emoji">
								<TextBlock.Style>
									<Style TargetType="TextBlock">
										<Style.Triggers>
											<DataTrigger Binding="{Binding IsHead}" Value="True">
												<Setter Property="FontWeight" Value="Bold"/>
												<Setter Property="FontSize" Value="24"/>
											</DataTrigger>
											<DataTrigger Binding="{Binding Type}" Value="Food">
												<Setter Property="FontSize" Value="24"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</TextBlock.Style>
							</TextBlock>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</Border>

		<Border Grid.Row="2" Background="#FFE8DCC8" Margin="0,10,0,0" Padding="8" CornerRadius="5">
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
				<TextBlock Text="🎮 Управление: " FontSize="14" FontWeight="Bold"/>
				<TextBlock Text="↑ ↓ ← →" FontSize="14" FontWeight="Bold" Foreground="DarkGreen"/>
				<TextBlock Text="    |    " FontSize="14"/>
				<TextBlock Text="␣ (пробел)" FontSize="14" FontWeight="Bold" Foreground="DarkBlue"/>
				<TextBlock Text=" - новая игра" FontSize="14"/>
			</StackPanel>
		</Border>
	</Grid>
</Window>