<Window x:Class="Calculator.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:Calculator.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Калькулятор" Height="550" Width="350">

    <!-- Установка DataContext -->
    <Window.DataContext>
        <viewmodels:MainWindowViewModel />
    </Window.DataContext>

    <!-- Основной интерфейс -->
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Дисплей -->
        <TextBlock Grid.Row="0" Text="{Binding DisplayValue}" 
                   FontSize="48" TextAlignment="Right"
                   Padding="10" Background="Black" Foreground="White" Margin="0,0,0,20"/>

        <!-- Кнопки -->
        <UniformGrid Grid.Row="1" Columns="4" Rows="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <!-- Row 0 -->
            <Button Content="C" FontSize="24" Background="#E0E0E0" Foreground="Black" Click="ClearButton_Click"/>
            <Button Content="+/-" FontSize="24" Background="#E0E0E0" Foreground="Black" Click="DigitButton_Click"/>
            <Button Content="%" FontSize="24" Background="#E0E0E0" Foreground="Black" Click="Procent_Click"/>
            <Button Content="÷" FontSize="24" Background="#FF9F0A" Foreground="White" Click="OperationButton_Click"/>

            <!-- Row 1 -->
            <Button Content="7" FontSize="24" Background="#333333" Foreground="White" Click="DigitButton_Click"/>
            <Button Content="8" FontSize="24" Background="#333333" Foreground="White" Click="DigitButton_Click"/>
            <Button Content="9" FontSize="24" Background="#333333" Foreground="White" Click="DigitButton_Click"/>
            <Button Content="×" FontSize="24" Background="#FF9F0A" Foreground="White" Click="OperationButton_Click"/>

            <!-- Row 2 -->
            <Button Content="4" FontSize="24" Background="#333333" Foreground="White" Click="DigitButton_Click"/>
            <Button Content="5" FontSize="24" Background="#333333" Foreground="White" Click="DigitButton_Click"/>
            <Button Content="6" FontSize="24" Background="#333333" Foreground="White" Click="DigitButton_Click"/>
            <Button Content="-" FontSize="24" Background="#FF9F0A" Foreground="White" Click="OperationButton_Click"/>

            <!-- Row 3 -->
            <Button Content="1" FontSize="24" Background="#333333" Foreground="White" Click="DigitButton_Click"/>
            <Button Content="2" FontSize="24" Background="#333333" Foreground="White" Click="DigitButton_Click"/>
            <Button Content="3" FontSize="24" Background="#333333" Foreground="White" Click="DigitButton_Click"/>
            <Button Content="+" FontSize="24" Background="#FF9F0A" Foreground="White" Click="OperationButton_Click"/>

            <!-- Row 4 -->
            <Button Content="⌫" FontSize="24" Background="#E0E0E0" Foreground="Black" Click="BackspaceButton_Click"/>
            <Button Content="0" FontSize="24" Background="#333333" Foreground="White" Click="DigitButton_Click"/>
            <Button Content="," FontSize="24" Background="#333333" Foreground="White" Click="Button_Click"/>
            <Button Content="=" FontSize="24" Background="#FF9F0A" Foreground="White" Click="OperationButton_Click"/>

            <Button Grid.Row="4" Grid.Column="2" Content="⌫" FontSize="36" Margin="5" Click="BackspaceButton_Click"/>
            <Button Grid.Row="1" Grid.Column="4" Content="^" FontSize="36" Margin="5" Click="OperationButton_Click"/>
        </UniformGrid>
    </Grid>
</Window>