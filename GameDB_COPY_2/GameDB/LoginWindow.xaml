<Window x:Class="GameDB.Wpf.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в 2048" 
        Height="300" 
        Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="2048" 
                   FontSize="32" 
                   FontWeight="Bold" 
                   Foreground="#776E65" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Логин:" Width="100" VerticalAlignment="Center" FontSize="14"/>
            <TextBox x:Name="UsernameBox" Width="180" FontSize="14" Padding="5"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Пароль:" Width="100" VerticalAlignment="Center" FontSize="14"/>
            <PasswordBox x:Name="PasswordBox" Width="180" FontSize="14" Padding="5"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
            <Button Content="Войти" Width="90" Height="30" Margin="0,0,10,0" 
                    FontSize="14" Click="Login_Click"/>
            <Button Content="Регистрация" Width="90" Height="30" 
                    FontSize="14" Click="Register_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="4" x:Name="MessageText" 
                   Foreground="Red" HorizontalAlignment="Center" 
                   FontSize="12" Margin="0,5,0,0"/>
    </Grid>
</Window>