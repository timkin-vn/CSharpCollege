<Window x:Class="CardFile.Wpf.Views.CardEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Правка карточки" Height="450" Width="450" ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Text="Марка:" Margin="5" />
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Brand}" Margin="5" />

        <TextBlock Grid.Row="1" Text="Модель:" Margin="5" />
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ModelName}" Margin="5" />

        <TextBlock Grid.Row="2" Text="Год выпуска:" Margin="5" />
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Year}" Margin="5" />

        <TextBlock Grid.Row="3" Text="VIN код:" Margin="5" />
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding VinCode}" Margin="5" />

        <TextBlock Grid.Row="4" Text="Цена:" Margin="5" />
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Price}" Margin="5" />

        <TextBlock Grid.Row="5" Text="Тип двигателя:" Margin="5" />
        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding EngineType}" Margin="5" />

        <TextBlock Grid.Row="6" Text="Объем двигателя:" Margin="5" />
        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding EngineVolume}" Margin="5" />

        <TextBlock Grid.Row="7" Text="Дата ТО:" Margin="5" />
        <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
            <DatePicker SelectedDate="{Binding LastServiceDate}" Margin="5" />
            <CheckBox IsChecked="{Binding IsWorkingTillNow}" Content="Нет данных" Margin="5" VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock Grid.Row="8" Text="Пробег:" Margin="5" />
        <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding Mileage}" Margin="5" />

        <TextBlock Grid.Row="9" Text="Цвет:" Margin="5" />
        <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding Color}" Margin="5" />

        <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Сохранить" Width="100" Margin="5" Click="Accept_Click" IsDefault="True" />
            <Button Content="Отмена" Width="100" Margin="5" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>