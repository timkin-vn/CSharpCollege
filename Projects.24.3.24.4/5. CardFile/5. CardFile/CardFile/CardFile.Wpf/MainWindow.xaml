<Window x:Class="CardFile.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.Wpf" xmlns:viewmodels="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Каталог видеоигр" Height="450" Width="1050"
        Loaded="Window_Loaded">
    <Window.DataContext>
        <viewmodels:MainWindowViewModel />
    </Window.DataContext>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Открыть..." Click="FileOpenMenuItem_Click" />
                <MenuItem Header="_Сохранить" Click="FileSaveMenuItem_Click" />
                <MenuItem Header="Со_хранить как..." Click="FileSaveAsMenuItem_Click" />
                <Separator />
                <MenuItem Header="В_ыход" Click="FileExitMenuItem_Click" />
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid ItemsSource="{Binding Cards}" SelectedItem="{Binding SelectedCard}" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" Grid.Row="0" Margin="5" SelectionChanged="DataGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Игра" Binding="{Binding GameInfo}" Width="2*" />
                    <DataGridTextColumn Header="Жанр" Binding="{Binding Genre}" Width="*" />
                    <DataGridTextColumn Header="Разработчик" Binding="{Binding Developer}" Width="*" />
                    <DataGridTextColumn Header="Релиз" Binding="{Binding ReleaseDateText}" Width="*" />
                    <DataGridTextColumn Header="Покупка" Binding="{Binding PurchaseDateText}" Width="*" />
                    <DataGridTextColumn Header="Прохождение" Binding="{Binding CompletionDateText}" Width="*" />
                    <DataGridTextColumn Header="Цена" Binding="{Binding PriceText}" Width="*" />
                    <DataGridTextColumn Header="Оценка" Binding="{Binding PersonalRating}" Width="*" />
                    <DataGridTextColumn Header="Тип" Binding="{Binding MediaTypeText}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Создать" Padding="5" Margin="5" VerticalAlignment="Center" Click="CreateCardButton_Click" />
                <Button Content="Правка" IsEnabled="{Binding IsEditButtonEnabled}" Padding="5" Margin="5" VerticalAlignment="Center"
                        Click="EditCardButton_Click" />
                <Button Content="Удалить" IsEnabled="{Binding IsDeleteButtonEnabled}" Padding="5" Margin="5" VerticalAlignment="Center"
                        Click="DeleteCardButton_Click" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
