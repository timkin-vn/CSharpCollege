<Window x:Class="CardFile.Wpf.Views.CardEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardFile.Wpf.Views" xmlns:viewmodels="clr-namespace:CardFile.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Правка карточки игры" Height="500" Width="520" ResizeMode="NoResize">
    <Window.DataContext>
        <viewmodels:CardViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" VerticalAlignment="Center" Margin="5" />
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Title}" Width="240" Margin="5" HorizontalAlignment="Left" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Серия:" VerticalAlignment="Center" Margin="5" />
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Series}" Width="240" Margin="5" HorizontalAlignment="Left" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Платформа:" VerticalAlignment="Center" Margin="5" />
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Platform}" Width="240" Margin="5" HorizontalAlignment="Left" />

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Жанр:" VerticalAlignment="Center" Margin="5" />
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Genre}" Width="240" Margin="5" HorizontalAlignment="Left" />

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Разработчик:" VerticalAlignment="Center" Margin="5" />
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Developer}" Width="240" Margin="5" HorizontalAlignment="Left" />

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Дата релиза:" VerticalAlignment="Center" Margin="5" />
        <DatePicker Grid.Row="5" Grid.Column="1" SelectedDate="{Binding ReleaseDate}" Margin="5" HorizontalAlignment="Left" />

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Дата покупки:" VerticalAlignment="Center" Margin="5" />
        <DatePicker Grid.Row="6" Grid.Column="1" SelectedDate="{Binding PurchaseDate}" Margin="5" HorizontalAlignment="Left" />

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Дата прохождения:" VerticalAlignment="Center" Margin="5" />
        <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
            <DatePicker SelectedDate="{Binding CompletionDate}" IsEnabled="{Binding IsCompletionDateEnabled}"
                        Margin="5" HorizontalAlignment="Left" />
            <CheckBox IsChecked="{Binding IsNotCompleted}" Margin="5"
                      Checked="IsNotCompletedCheckBox_Checked" Unchecked="IsNotCompletedCheckBox_Unchecked">
                <TextBlock Text="Еще не пройдена" VerticalAlignment="Center" />
            </CheckBox>
        </StackPanel>

        <TextBlock Grid.Row="8" Grid.Column="0" Text="Цена:" VerticalAlignment="Center" Margin="5" />
        <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding Price}" Width="240" Margin="5" HorizontalAlignment="Left" />

        <TextBlock Grid.Row="9" Grid.Column="0" Text="Личная оценка:" VerticalAlignment="Center" Margin="5" />
        <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding PersonalRating}" Width="80" Margin="5" HorizontalAlignment="Left" />

        <TextBlock Grid.Row="10" Grid.Column="0" Text="Тип издания:" VerticalAlignment="Center" Margin="5" />
        <CheckBox Grid.Row="10" Grid.Column="1" IsChecked="{Binding IsDigital}" Margin="5" HorizontalAlignment="Left">
            <TextBlock Text="Цифровая версия" VerticalAlignment="Center" />
        </CheckBox>

        <StackPanel Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Padding="5" Margin="5" Click="OkButton_Click" />
            <Button Content="Отмена" Padding="5" Margin="5" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
