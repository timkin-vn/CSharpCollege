<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - 2048</title>
    <style>
        body { font-family: Segoe UI, Arial, sans-serif; background: #FAF8EF; color: #776E65; }
        .wrap { width: 460px; margin: 30px auto; }
        h1 { font-size: 48px; margin: 0; }
        table.board { border-collapse: collapse; background: #BBADA0; border-radius: 8px; }
        table.board td { width: 100px; height: 100px; text-align: center; vertical-align: middle;
                         font-size: 32px; font-weight: bold; border: 6px solid #BBADA0; border-radius: 6px; }
        .controls { margin-top: 14px; }
        .controls button, .controls a.btn { font-size: 16px; padding: 8px 14px; margin: 2px;
                         border: none; border-radius: 4px; background: #8F7A66; color: white; cursor: pointer; text-decoration: none; }
        .status { margin-top: 12px; font-size: 18px; }
    </style>
</head>
<body>
    <div class="wrap">
        @RenderBody()
    </div>
</body>
</html>
