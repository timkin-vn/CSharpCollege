@model Game2048.Web.Models.GameViewModel
@{
    ViewBag.Title = "Игра";
}

<h1>2048</h1>
<p>Счёт: <b>@Model.Score</b> &nbsp; Ходы: <b>@Model.MoveCount</b></p>

<table class="board">
    @for (int r = 0; r < Model.Size; r++)
    {
        <tr>
            @for (int c = 0; c < Model.Size; c++)
            {
                var value = Model.Field[r, c];
                var bg = ColorFor(value);
                <td style="background:@bg; color:@(value <= 4 ? "#776E65" : "white")">
                    @(value == 0 ? "" : value.ToString())
                </td>
            }
        </tr>
    }
</table>

<div class="controls">
    @using (Html.BeginForm("MakeMove", "Game", FormMethod.Post, new { id = "moveForm" }))
    {
        <input type="hidden" name="directionText" id="directionText" />
        <button type="button" onclick="move('Up')">↑</button><br />
        <button type="button" onclick="move('Left')">←</button>
        <button type="button" onclick="move('Down')">↓</button>
        <button type="button" onclick="move('Right')">→</button>
    }
    <a class="btn" href="@Url.Action("New", "Game")">Новая игра</a>
</div>

<div class="status">@Model.Status</div>

<script>
    function move(dir) {
        document.getElementById('directionText').value = dir;
        document.getElementById('moveForm').submit();
    }
    document.addEventListener('keydown', function (e) {
        switch (e.key) {
            case 'ArrowLeft': move('Left'); break;
            case 'ArrowRight': move('Right'); break;
            case 'ArrowUp': move('Up'); break;
            case 'ArrowDown': move('Down'); break;
            default: return;
        }
        e.preventDefault();
    });
</script>

@functions {
    string ColorFor(int v)
    {
        switch (v)
        {
            case 0: return "#CDC1B4";
            case 2: return "#EEE4DA";
            case 4: return "#EDE0C8";
            case 8: return "#F2B179";
            case 16: return "#F59563";
            case 32: return "#F67C5F";
            case 64: return "#F65E3B";
            case 128: return "#EDCF72";
            case 256: return "#EDCC61";
            case 512: return "#EDC850";
            case 1024: return "#EDC53F";
            case 2048: return "#EDC22E";
            default: return "#3C3A32";
        }
    }
}
