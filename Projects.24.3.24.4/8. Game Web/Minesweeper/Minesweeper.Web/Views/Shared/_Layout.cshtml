<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Сапёр</title>
    <style>
        body { font-family: Segoe UI, Arial, sans-serif; background: #FAFAFA; color: #37474F; }
        .wrap { width: 460px; margin: 30px auto; }
        h1 { font-size: 44px; margin: 0; }
        table.board { border-collapse: collapse; background: #9E9E9E; border-radius: 4px; }
        table.board td { width: 38px; height: 38px; text-align: center; vertical-align: middle;
                         font-size: 20px; font-weight: bold; border: 1px solid #757575;
                         cursor: pointer; user-select: none; }
        .controls { margin-top: 14px; }
        .controls button, .controls a.btn { font-size: 16px; padding: 8px 14px; margin: 2px;
                         border: none; border-radius: 4px; background: #546E7A; color: white;
                         cursor: pointer; text-decoration: none; }
        .status { margin-top: 12px; font-size: 18px; }
    </style>
</head>
<body>
    <div class="wrap">
        @RenderBody()
    </div>
</body>
</html>
