@model FifteenGame.Web.Models.GameViewModel

@{
    ViewBag.Title = "Шаурма Бизнес Симулятор";
    bool isGameOver = !string.IsNullOrEmpty(Model.GameStatusMessage);
}

<main class="text-center" style="margin-top: 20px;">
    <h2>Шаурма Бизнес Симулятор (Web-Издание)</h2>

    @if (isGameOver)
    {
        <h3 class="text-info" style="margin-top: 15px; font-weight: bold;">@Model.GameStatusMessage</h3>
        <div style="margin-bottom: 20px;">
            <a href="@Url.Action("Reset", "Game")" class="btn btn-success btn-lg">Начать заново</a>
        </div>
    }
    else
    {
        <div style="margin-bottom: 20px;">
            <span style="font-size: 22px; font-weight: bold; color: green; margin-right: 40px;">@Model.MoneyText</span>
            <span style="font-size: 22px; font-weight: bold; color: blue; margin-right: 40px;">@Model.TurnsText</span>
            <a href="@Url.Action("Reset", "Game")" class="btn btn-warning">Сбросить игру</a>
        </div>
    }

    <div class="container d-flex justify-content-center">
        <div style="display: inline-block;">
            @for (int row = 0; row < Model.RowCount; row++)
            {
                <div class="row" style="margin-bottom: 8px; width: 600px;">
                    @for (int column = 0; column < Model.ColumnCount; column++)
                    {
                        var cell = Model.Cells[row, column];

                        <div class="col" style="padding: 0 4px;">
                            <div style="width: 105px; height: 105px; background-color: @cell.CellBackground;
                                        border: 2px solid #2f4f4f; border-radius: 10px;
                                        display: flex; align-items: center; justify-content: center;">

                                @if (cell.HasShop || isGameOver)
                                {
                                    <div style="font-size: 14px; font-weight: bold; white-space: pre-line; color: black;">
                                        @cell.Text
                                    </div>
                                }
                                else
                                {
                                    <a href="@Url.Action("MakeMove", "Game", new { row = row, column = column })"
                                       style="display: flex; width: 100%; height: 100%; align-items: center; justify-content: center;
                                              text-decoration: none; color: black; font-size: 14px; font-weight: bold; white-space: pre-line;">
                                        @cell.Text
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</main>