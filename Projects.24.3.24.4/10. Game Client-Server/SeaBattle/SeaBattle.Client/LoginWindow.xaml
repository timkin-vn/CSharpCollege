<Window x:Class="SeaBattle.Wpf.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="200" Width="340" Background="#1a1c23"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="МОРСКОЙ БОЙ" FontSize="18" FontWeight="Bold" Foreground="#4cc9f0" HorizontalAlignment="Center"/>

        <TextBox Grid.Row="1" x:Name="NameBox" FontSize="14" Height="32" VerticalContentAlignment="Center" Margin="0,15" Padding="8,0" Background="#242731" Foreground="#ffffff" BorderBrush="#3a3f50"/>

        <Button Grid.Row="2" Content="ИГРАТЬ" FontSize="14" FontWeight="Bold" Height="36" Background="#4cc9f0" Foreground="#1a1c23" Click="EnterButton_Click"/>
    </Grid>
</Window>