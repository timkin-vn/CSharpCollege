<Window x:Class="Game2048.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="2048" Height="660" Width="500" Background="#FAF8EF"
        KeyDown="Window_KeyDown" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="2048" FontSize="40" FontWeight="Bold" Foreground="#776E65"/>
            <TextBlock Text="{Binding PlayerName}" FontSize="18" Foreground="#776E65"
                       VerticalAlignment="Bottom" Margin="16,0,0,8"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10" VerticalAlignment="Center">
            <TextBlock Text="Счёт: " FontSize="18" Foreground="#776E65" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Score}" FontSize="18" FontWeight="Bold" Foreground="#776E65" VerticalAlignment="Center"/>
            <TextBlock Text="    Ходы: " FontSize="18" Foreground="#776E65" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding MoveCount}" FontSize="18" FontWeight="Bold" Foreground="#776E65" VerticalAlignment="Center"/>
            <Button Content="Новая игра" Command="{Binding NewGameCommand}" Margin="24,0,0,0" Padding="12,4"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#BBADA0" CornerRadius="8" Padding="6" Margin="0,10">
            <ItemsControl ItemsSource="{Binding Cells}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="4" Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5" CornerRadius="5" Background="{Binding Background}">
                            <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}"
                                       FontSize="30" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <TextBlock Grid.Row="3" Text="{Binding Status}" FontSize="16" Foreground="#776E65"
                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
    </Grid>
</Window>
