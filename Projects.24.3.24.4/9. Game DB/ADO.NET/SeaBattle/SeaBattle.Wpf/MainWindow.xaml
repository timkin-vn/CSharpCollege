<Window x:Class="SeaBattle.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Морской бой" Height="560" Width="720"
        Background="#0D1B2A" ResizeMode="CanMinimize">
    <Window.Resources>
        <DataTemplate x:Key="CellTemplate">
            <Border Width="26" Height="26" Margin="1" CornerRadius="3"
                    Background="{Binding Background}" MouseLeftButtonUp="Cell_Click">
                <TextBlock Text="{Binding Text}" Foreground="White" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="Морской бой — " FontSize="22" FontWeight="Bold" Foreground="#E6F1FF"/>
            <TextBlock Text="{Binding UserName}" FontSize="22" FontWeight="Bold" Foreground="#9BF8F4"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,10">
            <TextBlock Text="{Binding Status}" FontSize="14" Foreground="#8FB3D6"/>
            <TextBlock Text="   |   " FontSize="14" Foreground="#48637f"/>
            <TextBlock Text="{Binding HistoryText}" FontSize="14" Foreground="#8FB3D6"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="36"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Ваш флот" Foreground="#8FB3D6" Margin="0,0,0,6"/>
                <Border Background="#152A40" CornerRadius="8" Padding="6">
                    <ItemsControl ItemsSource="{Binding PlayerCells}" ItemTemplate="{StaticResource CellTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Rows="10" Columns="10"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Поле противника" Foreground="#8FB3D6" Margin="0,0,0,6"/>
                <Border Background="#152A40" CornerRadius="8" Padding="6">
                    <ItemsControl ItemsSource="{Binding EnemyCells}" ItemTemplate="{StaticResource CellTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Rows="10" Columns="10"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,14,0,0">
            <Button Content="Перетасовать" Command="{Binding ShuffleCommand}" Padding="12,5" Margin="0,0,10,0"/>
            <Button Content="В бой!" Command="{Binding StartCommand}" Padding="12,5" Margin="0,0,10,0"/>
            <Button Content="Новая игра" Command="{Binding NewGameCommand}" Padding="12,5"/>
        </StackPanel>
    </Grid>
</Window>
