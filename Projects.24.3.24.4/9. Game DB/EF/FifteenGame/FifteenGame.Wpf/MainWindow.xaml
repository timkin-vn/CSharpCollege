<Window x:Class="FifteenGame.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FifteenGame.Wpf" 
        xmlns:viewmodels="clr-namespace:FifteenGame.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Шаурмичная Империя 5х5" Height="700" Width="900" MinHeight="650" MinWidth="600">

    <Window.DataContext>
        <viewmodels:MainWindowViewModel />
    </Window.DataContext>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#333333" Padding="15" CornerRadius="0,0,10,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0">

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="💰 Баланс: " Foreground="White" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="{Binding Money}" Foreground="#FFD700" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text=" руб." Foreground="White" FontSize="18" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔥 Стрик побед: " Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding WinStreak}" Foreground="Orange" FontSize="14" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" 
                Content="Начать заново" 
                Command="{Binding RestartCommand}" 
                Width="130" 
                Height="32" 
                Background="#FF444444" 
                BorderBrush="WhiteSmoke" 
                Foreground="WhiteSmoke"
                VerticalAlignment="Center">
                    <Button.Resources>
                        
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0">
                    <TextBlock Text="📊 Сделано ходов: " Foreground="White" FontSize="18" />
                    <TextBlock Text="{Binding TurnsPlayed}" Foreground="#00FF7F" FontSize="18" FontWeight="Bold" />
                    <TextBlock Text=" из 15" Foreground="Gray" FontSize="18" Margin="5,0,0,0" />
                </StackPanel>

            </Grid>
        </Border>

        <TextBlock Grid.Row="1" Text="{Binding StatusText}" HorizontalAlignment="Center" Margin="5" FontSize="16" FontWeight="SemiBold" Foreground="#555555" />

        <ItemsControl Grid.Row="2" ItemsSource="{Binding Cells}" HorizontalAlignment="Center" VerticalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="90" />
                            <RowDefinition Height="90" />
                            <RowDefinition Height="90" />
                            <RowDefinition Height="90" />
                            <RowDefinition Height="90" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="110" />
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Margin="4" 
                Command="{Binding DataContext.CellClickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                CommandParameter="{Binding}"
                Background="{Binding CellBackground}"
                        BorderBrush="SlateGray"
                BorderThickness="2">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                        <TextBlock Text="{Binding Text}" FontSize="11" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Medium" />
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>

            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Grid.Row" Value="{Binding Row}" />
                    <Setter Property="Grid.Column" Value="{Binding Column}" />
                </Style>
            </ItemsControl.ItemContainerStyle>
        </ItemsControl>

        <TextBlock Grid.Row="3" Text="Клик по закрытой клетке: Разведка (50 руб) | Клик по открытой: Построить ларёк (300 руб)" 
                   HorizontalAlignment="Center" Margin="10" FontSize="12" Foreground="Gray" />
    </Grid>
</Window>