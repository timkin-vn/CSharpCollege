<Window x:Class="Minesweeper.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Minesweeper.Wpf.ViewModels"
        Title="Сапёр" Height="560" Width="430"
        Background="#FAFAFA">
    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Сапёр" FontSize="40" FontWeight="Bold" Foreground="#37474F"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10" VerticalAlignment="Center">
            <TextBlock Text="Мины: " FontSize="18" Foreground="#37474F" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding MinesRemaining}" FontSize="18" FontWeight="Bold" Foreground="#37474F" VerticalAlignment="Center"/>
            <TextBlock Text="    Ходы: " FontSize="18" Foreground="#37474F" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding MoveCount}" FontSize="18" FontWeight="Bold" Foreground="#37474F" VerticalAlignment="Center"/>
            <Button Content="Новая игра" Command="{Binding NewGameCommand}" Margin="24,0,0,0" Padding="12,4"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#9E9E9E" CornerRadius="4" Padding="4" Margin="0,10">
            <ItemsControl ItemsSource="{Binding Cells}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="9" Columns="9"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Margin="1"
                                Command="{Binding RevealCommand}"
                                Content="{Binding Text}"
                                Background="{Binding Background}"
                                Foreground="{Binding Foreground}"
                                FontSize="18" FontWeight="Bold"
                                BorderBrush="#757575" BorderThickness="1">
                            <Button.InputBindings>
                                <MouseBinding MouseAction="RightClick" Command="{Binding FlagCommand}"/>
                            </Button.InputBindings>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <TextBlock Grid.Row="3" Text="{Binding Status}" FontSize="16" Foreground="#37474F"
                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
    </Grid>
</Window>
